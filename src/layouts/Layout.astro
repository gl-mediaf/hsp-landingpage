---
import PostHog from '../components/posthog.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "hsp – Der Ferienjob mit dem gewissen Etwas",
  description = "Verdiene bis zu 3.500€ in 4 Wochen. Lerne Rhetorik, Kommunikation & echte Menschenkenntnis – Skills fürs Leben. Jetzt bei hsp bewerben.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="64x64" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TP6LV2M');</script>
    <!-- End Google Tag Manager -->

    <PostHog />

    <!-- UTM param persistence -->
    <script>
      (function(){
        var p = new URLSearchParams(window.location.search);
        ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','fbclid','gclid','ScCid'].forEach(function(k){
          if (p.get(k)) sessionStorage.setItem(k, p.get(k));
        });
      })();
    </script>
  </head>
  <body class="bg-white text-hsp-dark antialiased overflow-x-hidden">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TP6LV2M"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>
