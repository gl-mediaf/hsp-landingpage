---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="hsp – Der Ferienjob mit dem gewissen Etwas"
  description="Mach Ø 3.300 € in 4 Wochen. Für den guten Zweck von Tür zu Tür. Jetzt anfragen."
>

<div id="app">

  <!-- ══════════════════════════════════════════════════════
       PAGE 1 — HOOK & INFO
  ══════════════════════════════════════════════════════════ -->
  <div id="page-1" class="page active">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 nav-blur">
      <div class="text-white font-black text-xl tracking-tight">hsp</div>
      <div class="hidden md:flex gap-8 text-sm text-white/60 font-medium">
        <a href="#was-du-machst" class="hover:text-white transition-colors">Was du machst</a>
        <a href="#community" class="hover:text-white transition-colors">Community</a>
      </div>
      <button onclick="goToPage(3)" class="btn-ghost text-sm">Jetzt anfragen →</button>
    </nav>

    <!-- HERO -->
    <section class="relative min-h-screen flex flex-col justify-end overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/3.png" alt="" class="w-full h-full object-cover object-center" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/60 to-[#0a0a0a]/10"></div>
      </div>
      <div class="relative z-10 px-6 md:px-16 pb-20 pt-32 max-w-5xl">
        <div class="inline-flex items-center gap-2 bg-hsp-lime/10 border border-hsp-lime/30 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-hsp-lime animate-pulse"></span>
          <span class="text-hsp-lime text-sm font-semibold">Jetzt für Sommer & Herbst verfügbar</span>
        </div>
        <h1 class="text-white font-black leading-[0.92] mb-6" style="font-size: clamp(3.5rem,10vw,7rem)">
          3 Monate<br />
          <span class="text-hsp-lime">arbeiten.</span><br />
          9 Monate<br />
          reisen.
        </h1>
        <p class="text-white/70 text-lg md:text-xl max-w-xl leading-relaxed">
          Für den guten Zweck von Tür zu Tür unterwegs –<br class="hidden md:block" />
          und dabei richtig gutes Geld machen.
        </p>
        <div class="mt-12 flex items-center gap-3 text-white/40 text-sm">
          <div class="scroll-dot-wrap"><span class="scroll-dot"></span></div>
          Scroll
        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF BAR -->
    <section class="bg-[#111] border-y border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-5 flex flex-wrap items-center justify-center md:justify-between gap-6">
        {[
          { num: 'Ø 3.300 €', label: 'in 4 Wochen' },
          { num: '25+',       label: 'Jahre Erfahrung' },
          { num: '18+',       label: 'Mindestalter' },
          { num: 'Jan–Nov',   label: 'Verfügbar' },
        ].map((s, i) => (
          <>
            <div class="flex flex-col items-center gap-0.5">
              <span class="text-white font-extrabold text-lg">{s.num}</span>
              <span class="text-white/40 text-xs">{s.label}</span>
            </div>
            {i < 3 && <div class="hidden md:block w-px h-8 bg-white/10"></div>}
          </>
        ))}
      </div>
    </section>

    <!-- WAS DU MACHST -->
    <section id="was-du-machst" class="bg-[#0a0a0a] py-24 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="section-label">Was du machst</p>
          <h2 class="section-h text-white">
            Du überzeugst Menschen<br />für den <span class="text-hsp-lime">guten Zweck.</span>
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mt-6 mb-8">
            Als Fundraiser bist du für renommierte Hilfsorganisationen von Tür zu Tür
            unterwegs – und begeisterst Menschen im direkten Gespräch für fördernde
            Mitgliedschaften. Nicht einfach. Genau deshalb machst du richtig gutes Geld.
          </p>
          <ul class="space-y-4">
            {[
              'Direkter Kontakt – persönlich & überzeugend',
              'Modernes Tablet für reibungslose Abwicklung',
              'Crew Coach begleitet dich von Tag 1',
              'Freiwillige Coachings: Rhetorik, Sales & Kommunikation',
            ].map(item => (
              <li class="flex items-start gap-3 text-white/70">
                <span class="mt-1 shrink-0 w-5 h-5 rounded-full bg-hsp-lime/20 flex items-center justify-center">
                  <svg class="w-3 h-3 text-hsp-lime" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img src="/images/1.png" alt="Fundraiser im Gespräch" class="w-full rounded-2xl object-cover aspect-[4/5]" />
          <div class="absolute -bottom-4 -left-4 bg-hsp-lime rounded-2xl px-5 py-4 shadow-xl">
            <p class="text-[#0a0a0a] font-black text-2xl">Ø 3.300 €</p>
            <p class="text-[#0a0a0a]/70 text-sm font-medium">in 4 Wochen</p>
          </div>
        </div>
      </div>

      <!-- Org logos -->
      <div class="max-w-6xl mx-auto mt-20 text-center">
        <p class="text-white/30 text-xs uppercase tracking-widest mb-8">Unterwegs für diese Organisationen</p>
        <div class="flex flex-wrap items-center justify-center gap-10">
          {['Deutsches Rotes Kreuz', 'BUND', 'Malteser', 'BN Bayern', 'Österr. Rotes Kreuz'].map(org => (
            <span class="text-white/50 font-semibold text-sm">{org}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- PHONE MOCKUP – UGC -->
    <section class="bg-[#0f0f0f] py-24 px-6 overflow-hidden">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
        <div class="md:w-1/2">
          <p class="section-label">Ein Tag als Fundraiser</p>
          <h2 class="section-h text-white">
            Schau rein –<br /><span class="text-hsp-lime">echter Alltag.</span>
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mt-6">
            Kein Büro, kein 9-to-5. Du bist draußen, im Gespräch,
            mit deiner Crew unterwegs – und wächst mit jeder Tür.
          </p>
        </div>
        <div class="md:w-1/2 flex justify-center">
          <div class="phone-mockup">
            <div class="phone-notch"></div>
            <div class="phone-screen" id="ugc-screen">
              <div class="ugc-slides" id="ugc-slides">
                {[
                  { img: '/images/4.png', tag: '@fundraiser_life',  text: 'Tag 3 – schon 12 EH heute 🔥' },
                  { img: '/images/7.png', tag: '@hsp_crew',         text: 'Crew Dinner nach nem langen Tag 🍕' },
                  { img: '/images/2.png', tag: '@leo.fundraiser',   text: 'Woche 2 – Faktor steigt, Konto auch 💸' },
                ].map(s => (
                  <div class="ugc-slide">
                    <img src={s.img} alt="" />
                    <div class="ugc-overlay">
                      <p class="ugc-tag">{s.tag}</p>
                      <p class="ugc-text">{s.text}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="ugc-dots">
                <span class="ugc-dot active" onclick="goToSlide(0)"></span>
                <span class="ugc-dot"        onclick="goToSlide(1)"></span>
                <span class="ugc-dot"        onclick="goToSlide(2)"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMUNITY -->
    <section id="community" class="bg-[#0a0a0a] py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="section-label">Community</p>
          <h2 class="section-h text-white text-center">
            Deine Community<br /><span class="text-hsp-lime">wartet auf dich.</span>
          </h2>
          <p class="text-white/60 text-lg mt-4 max-w-xl mx-auto">
            Neue Freundschaften, unvergessliche Erlebnisse, echte Verbindungen –
            das ist der Unterschied zu jedem anderen Job.
          </p>
        </div>
        <div class="community-grid">
          <img src="/images/6.png"  alt="" class="community-img tall" />
          <img src="/images/8.png"  alt="" class="community-img" />
          <img src="/images/10.png" alt="" class="community-img" />
          <img src="/images/5.png"  alt="" class="community-img tall" />
          <img src="/images/11.png" alt="" class="community-img" />
          <img src="/images/12.png" alt="" class="community-img" />
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="bg-[#0f0f0f] py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="section-label">Bewertungen</p>
          <div class="flex items-center justify-center gap-2 mt-2">
            <div class="flex gap-1">★★★★★</div>
            <span class="text-white font-bold text-lg">4.8</span>
            <span class="text-white/40 text-sm">auf Google</span>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { name: 'Maximilian K.', age: 22, text: 'Dieser Job hat mich verändert. Ich rede heute mit jedem – selbstbewusst, klar, überzeugend. Das Geld war super, aber die Skills sind unbezahlbar.' },
            { name: 'Lena S.',       age: 20, text: 'In 4 Wochen mehr gemacht als in meinem letzten Sommerjob in einem halben Jahr. Und das für einen guten Zweck. Kann ich nur empfehlen.' },
            { name: 'Jonas M.',      age: 24, text: 'Die Community ist das Beste. Man kommt als Fremder und geht mit Freunden fürs Leben. Nebenbei macht man richtig gutes Geld.' },
          ].map(r => (
            <div class="review-card">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-hsp-lime/20 flex items-center justify-center text-hsp-lime font-bold text-sm">
                  {r.name[0]}
                </div>
                <div>
                  <p class="text-white font-semibold text-sm">{r.name}, {r.age}</p>
                  <div class="text-yellow-400 text-xs mt-0.5">★★★★★</div>
                </div>
              </div>
              <p class="text-white/70 text-sm leading-relaxed">"{r.text}"</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="https://www.google.com/search?q=hsp+DIE+FUNDRAISER+GmbH+Rezensionen" target="_blank" class="text-hsp-lime/70 hover:text-hsp-lime text-sm underline transition-colors">
            Alle Bewertungen auf Google lesen →
          </a>
        </div>
      </div>
    </section>

    <!-- CTA TO PAGE 2 -->
    <section class="bg-[#0a0a0a] py-32 px-6 text-center">
      <p class="section-label">Geld machen</p>
      <h2 class="section-h text-white max-w-2xl mx-auto">
        Wie viel kannst<br />du <span class="text-hsp-lime">machen?</span>
      </h2>
      <p class="text-white/60 text-lg mt-4 mb-10 max-w-lg mx-auto">
        Kein fixes Gehalt – du bestimmst deinen Einsatz. Rechne selbst nach.
      </p>
      <button onclick="goToPage(2)" class="btn-primary text-lg px-10 py-4">
        Dein Geld ausrechnen →
      </button>
    </section>

  </div><!-- /page-1 -->


  <!-- ══════════════════════════════════════════════════════
       PAGE 2 — GELD MACHEN + RECHNER
  ══════════════════════════════════════════════════════════ -->
  <div id="page-2" class="page">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 nav-blur">
      <button onclick="goToPage(1)" class="text-white/50 hover:text-white transition-colors text-sm">← Zurück</button>
      <div class="text-white font-black text-xl tracking-tight">hsp</div>
      <button onclick="goToPage(3)" class="btn-ghost text-sm">Jetzt anfragen →</button>
    </nav>

    <!-- Mindestgarantie -->
    <section class="bg-[#0a0a0a] pt-32 pb-20 px-6">
      <div class="max-w-6xl mx-auto">
        <p class="section-label text-center">So machst du dein Geld</p>
        <h2 class="section-h text-white text-center mb-4">
          Dein Geld.<br /><span class="text-hsp-lime">Dein Einsatz.</span>
        </h2>
        <p class="text-white/60 text-lg text-center max-w-xl mx-auto mb-16">
          Du wirst nach Provision bezahlt. Je mehr Menschen du begeisterst,
          desto mehr machst du. Als Sicherheitsnetz gibt's eine garantierte Basis.
        </p>

        <div class="guarantee-card mb-4">
          <div class="flex flex-col md:flex-row md:items-center gap-8">
            <div class="md:w-1/3">
              <p class="text-white/40 text-xs uppercase tracking-widest mb-2">Garantierte Basis</p>
              <p class="text-hsp-lime font-black" style="font-size:3rem">2.400 €</p>
              <p class="text-white/50 mt-1 text-sm">Mindestprovision in 4 Wochen</p>
            </div>
            <div class="md:w-2/3 grid grid-cols-2 md:grid-cols-4 gap-3">
              {[
                { week: 'Woche 1', rate: '55 €' },
                { week: 'Woche 2', rate: '85 €' },
                { week: 'Woche 3', rate: '115 €' },
                { week: 'Woche 4', rate: '145 €' },
              ].map(w => (
                <div class="bg-white/4 rounded-xl p-4 border border-white/8">
                  <p class="text-white/40 text-xs mb-1">{w.week}</p>
                  <p class="text-white font-bold text-xl">{w.rate}</p>
                  <p class="text-white/30 text-xs">pro Tag</p>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-6 pt-5 border-t border-white/8 flex flex-wrap gap-6">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-hsp-lime shrink-0"></span>
              <span class="text-white/60 text-sm">+ <strong class="text-white">200 € Anreisebonus</strong> nach deinem 6. Einsatztag</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-hsp-lime shrink-0"></span>
              <span class="text-white/60 text-sm">Provision immer <strong class="text-white">"best case"</strong> abgerechnet</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- INTERAKTIVER RECHNER -->
    <section class="bg-[#0f0f0f] py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <p class="section-label text-center">Interaktiver Rechner</p>
        <h2 class="section-h text-white text-center mb-12">
          Rechne deinen<br /><span class="text-hsp-lime">Einsatz durch.</span>
        </h2>

        <div class="calc-card">

          <!-- Org select -->
          <div class="mb-10">
            <p class="calc-label">Organisation wählen</p>
            <div class="flex flex-wrap gap-3" id="org-grid">
              <!-- rendered by JS to keep data in one place -->
            </div>
          </div>

          <!-- Einheiten slider -->
          <div class="mb-8">
            <div class="flex justify-between items-end mb-3">
              <p class="calc-label mb-0">Einheiten in 4 Wochen</p>
              <span class="text-white font-black text-2xl" id="eh-display">300 EH</span>
            </div>
            <div class="relative">
              <input type="range" id="eh-slider" min="0" max="900" value="840" step="10"
                class="calc-slider w-full" oninput="updateCalc()" />
              <div class="flex justify-between text-xs text-white/30 mt-2">
                <span>0 EH</span>
                <span>900 EH</span>
              </div>
            </div>

            <!-- Level indicator -->
            <div class="level-track mt-5">
              <div class="level-fill" id="level-fill" style="width:33%"></div>
              <div class="level-labels">
                <span id="lbl-newcomer" class="level-lbl active-lbl">NEWCOMER</span>
                <span id="lbl-pro"      class="level-lbl">PRO</span>
                <span id="lbl-elite"    class="level-lbl">ELITE</span>
              </div>
            </div>
          </div>

          <!-- Result -->
          <div class="result-box" id="result-box">
            <div class="grid md:grid-cols-3 gap-6">
              <div>
                <p class="text-white/40 text-xs uppercase tracking-widest mb-1">Faktor</p>
                <p class="text-white font-black text-4xl" id="r-factor">7.0</p>
              </div>
              <div class="md:border-l md:border-white/10 md:pl-6">
                <p class="text-white/40 text-xs uppercase tracking-widest mb-1">Brutto-Provision</p>
                <p class="text-white font-black text-4xl" id="r-gross">2.100 €</p>
                <p class="text-white/30 text-xs mt-1">– 20 % Stornorücklage*</p>
              </div>
              <div class="md:border-l md:border-white/10 md:pl-6">
                <p class="text-hsp-lime text-xs uppercase tracking-widest mb-1 font-semibold">Dein Geld</p>
                <p class="text-hsp-lime font-black text-4xl" id="r-net">1.880 €</p>
                <p class="text-white/30 text-xs mt-1">inkl. 200 € Anreisebonus</p>
              </div>
            </div>

            <!-- What you can buy -->
            <div class="mt-8 pt-6 border-t border-white/10">
              <p class="text-white/30 text-xs uppercase tracking-widest mb-4">Das steckt dahinter</p>
              <div class="flex flex-wrap gap-2" id="buy-grid"></div>
            </div>
          </div>

          <p class="text-white/20 text-xs mt-4">
            * 20 % Stornorücklage werden nach 1,5 Jahren mit tatsächlichen Stornos verrechnet und ggf. zurückerstattet.
            Alle Angaben sind Beispielrechnungen ohne Gewähr.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA TO FORM -->
    <section class="bg-[#0a0a0a] py-32 px-6 text-center">
      <h2 class="section-h text-white max-w-xl mx-auto">
        Klingt gut?<br /><span class="text-hsp-lime">Dann frag an.</span>
      </h2>
      <p class="text-white/60 text-lg mt-4 mb-10 max-w-md mx-auto">
        Wir melden uns innerhalb von 24 Stunden. Keine Verpflichtung.
      </p>
      <button onclick="goToPage(3)" class="btn-primary text-lg px-10 py-4">
        Jetzt anfragen →
      </button>
    </section>

  </div><!-- /page-2 -->


  <!-- ══════════════════════════════════════════════════════
       PAGE 3 — MULTI-STEP FORM
  ══════════════════════════════════════════════════════════ -->
  <div id="page-3" class="page">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 nav-blur">
      <button onclick="goToPage(2)" class="text-white/50 hover:text-white transition-colors text-sm">← Zurück</button>
      <div class="text-white font-black text-xl tracking-tight">hsp</div>
      <div></div>
    </nav>

    <section class="min-h-screen bg-[#0a0a0a] flex items-center justify-center px-6 pt-24 pb-16">
      <div class="w-full max-w-lg">

        <div class="mb-10">
          <div class="flex justify-between text-xs text-white/40 mb-2">
            <span id="step-label">Schritt 1 von 3</span>
            <span id="step-pct">33 %</span>
          </div>
          <div class="h-1 bg-white/10 rounded-full overflow-hidden">
            <div class="h-full bg-hsp-lime rounded-full transition-all duration-500" id="progress-bar" style="width:33%"></div>
          </div>
        </div>

        <!-- Step 1 -->
        <div id="fs-1" class="fstep">
          <h2 class="text-white font-black text-3xl mb-2">Wer bist du?</h2>
          <p class="text-white/50 mb-8">Kurz vorstellen – das war's für Schritt 1.</p>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div class="fgroup">
                <label class="flabel">Vorname *</label>
                <input id="f-fn" type="text" class="finput" placeholder="Max" />
              </div>
              <div class="fgroup">
                <label class="flabel">Nachname *</label>
                <input id="f-ln" type="text" class="finput" placeholder="Mustermann" />
              </div>
            </div>
            <div class="fgroup">
              <label class="flabel">Alter *</label>
              <input id="f-age" type="number" class="finput" placeholder="21" min="18" />
            </div>
          </div>
          <button onclick="nextStep(2)" class="btn-primary w-full mt-8 py-4">Weiter →</button>
        </div>

        <!-- Step 2 -->
        <div id="fs-2" class="fstep hidden">
          <h2 class="text-white font-black text-3xl mb-2">Wie erreichst du dich?</h2>
          <p class="text-white/50 mb-8">Damit wir uns melden können.</p>
          <div class="space-y-4">
            <div class="fgroup">
              <label class="flabel">E-Mail *</label>
              <input id="f-email" type="email" class="finput" placeholder="max@beispiel.de" />
            </div>
            <div class="fgroup">
              <label class="flabel">Telefon *</label>
              <input id="f-phone" type="tel" class="finput" placeholder="+49 ..." />
            </div>
            <div class="fgroup">
              <label class="flabel">Beste Erreichbarkeit</label>
              <select id="f-reach" class="finput">
                <option value="">Bitte wählen …</option>
                <option>Vormittags</option>
                <option>Mittags</option>
                <option>Nachmittags</option>
                <option>Abends</option>
              </select>
            </div>
          </div>
          <div class="flex gap-3 mt-8">
            <button onclick="nextStep(1)" class="btn-ghost flex-1 py-4">← Zurück</button>
            <button onclick="nextStep(3)" class="btn-primary flex-1 py-4">Weiter →</button>
          </div>
        </div>

        <!-- Step 3 -->
        <div id="fs-3" class="fstep hidden">
          <h2 class="text-white font-black text-3xl mb-2">Fast geschafft.</h2>
          <p class="text-white/50 mb-8">Noch ein paar Details – dann sind wir fertig.</p>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div class="fgroup">
                <label class="flabel">Ort *</label>
                <input id="f-city" type="text" class="finput" placeholder="München" />
              </div>
              <div class="fgroup">
                <label class="flabel">PLZ *</label>
                <input id="f-plz" type="text" class="finput" placeholder="80331" />
              </div>
            </div>
            <div class="fgroup">
              <label class="flabel">Land</label>
              <select id="f-land" class="finput">
                <option>Deutschland</option>
                <option>Österreich</option>
                <option>Schweiz</option>
                <option>Sonstiges</option>
              </select>
            </div>
            <div class="fgroup">
              <label class="flabel">Was motiviert dich?</label>
              <textarea id="f-motive" class="finput" rows="3" placeholder="Kurz in eigenen Worten …"></textarea>
            </div>
            <p class="text-white/25 text-xs">
              Mit dem Absenden akzeptierst du unsere
              <a href="https://www.hsp-derjob.de/datenschutz/" target="_blank" class="underline hover:text-white/40">Datenschutzerklärung</a>.
            </p>
          </div>
          <div class="flex gap-3 mt-8">
            <button onclick="nextStep(2)" class="btn-ghost flex-1 py-4">← Zurück</button>
            <button onclick="submitForm()" class="btn-primary flex-1 py-4">Anfrage absenden ✓</button>
          </div>
        </div>

        <!-- Success -->
        <div id="fs-ok" class="fstep hidden text-center">
          <div class="w-16 h-16 rounded-full bg-hsp-lime/20 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-hsp-lime" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h2 class="text-white font-black text-3xl mb-3">Anfrage eingegangen!</h2>
          <p class="text-white/60 text-lg max-w-sm mx-auto">
            Danke – wir melden uns innerhalb von <strong class="text-white">24 Stunden</strong>.
            Schau sicherheitshalber auch in deinen Spam-Ordner.
          </p>
          <button onclick="goToPage(1)" class="btn-ghost mt-8 px-8 py-3">Zurück zur Startseite</button>
        </div>

      </div>
    </section>

  </div><!-- /page-3 -->

</div><!-- /app -->


<!-- ────────────────────────────────────────────────────── STYLES ── -->
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: #0a0a0a; color: #fff; overflow-x: hidden; font-family: 'Inter', system-ui, sans-serif; }

  /* Pages */
  .page { display: none; }
  .page.active { display: block; }

  /* Nav */
  .nav-blur {
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* Buttons */
  .btn-primary {
    background: #97BF0D; color: #0a0a0a;
    font-weight: 800; border-radius: 100px;
    border: none; cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    display: inline-block; text-align: center;
  }
  .btn-primary:hover { background: #aad40f; transform: translateY(-1px); }

  .btn-ghost {
    background: transparent; color: #fff;
    font-weight: 600; border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.2);
    cursor: pointer; transition: border-color 0.2s;
    display: inline-block; text-align: center;
    padding: 10px 20px;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.5); }

  /* Typography helpers */
  .section-label {
    display: block;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #97BF0D; margin-bottom: 12px;
  }
  .section-h {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900; line-height: 1.05;
  }

  /* Scroll indicator */
  .scroll-dot-wrap {
    width: 22px; height: 36px;
    border: 2px solid rgba(255,255,255,0.25);
    border-radius: 12px; position: relative;
  }
  .scroll-dot {
    position: absolute; left: 50%; top: 6px;
    width: 4px; height: 8px;
    background: rgba(255,255,255,0.5);
    border-radius: 4px; transform: translateX(-50%);
    animation: sdrop 2s ease-in-out infinite;
  }
  @keyframes sdrop {
    0%,100% { top: 6px; opacity: 1; }
    80%      { top: 18px; opacity: 0; }
  }

  /* Phone mockup */
  .phone-mockup {
    width: 270px; height: 550px;
    background: #1a1a1a;
    border-radius: 42px;
    border: 3px solid rgba(255,255,255,0.12);
    padding: 12px;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.04);
  }
  .phone-notch {
    position: absolute; top: 14px; left: 50%;
    transform: translateX(-50%);
    width: 70px; height: 5px;
    background: rgba(255,255,255,0.15);
    border-radius: 4px; z-index: 10;
  }
  .phone-screen {
    width: 100%; height: 100%;
    border-radius: 30px; overflow: hidden; position: relative;
  }
  .ugc-slides {
    display: flex; width: 300%; height: 100%;
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .ugc-slide {
    width: calc(100% / 3); height: 100%;
    position: relative; flex-shrink: 0;
  }
  .ugc-slide img { width: 100%; height: 100%; object-fit: cover; }
  .ugc-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 20px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.85));
  }
  .ugc-tag  { color: #97BF0D; font-size: 0.68rem; font-weight: 700; margin-bottom: 4px; }
  .ugc-text { color: #fff; font-size: 0.78rem; font-weight: 500; }
  .ugc-dots {
    position: absolute; bottom: 14px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 6px; z-index: 10;
  }
  .ugc-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.3);
    cursor: pointer; transition: all 0.25s;
  }
  .ugc-dot.active { background: #97BF0D; width: 18px; border-radius: 4px; }

  /* Community grid */
  .community-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 8px;
  }
  .community-img {
    width: 100%; height: 190px;
    object-fit: cover; border-radius: 12px;
    transition: transform 0.3s;
  }
  .community-img:hover { transform: scale(1.02); }
  .community-img.tall { height: 270px; }

  /* Review cards */
  .review-card {
    background: #161616;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 20px;
  }

  /* Guarantee card */
  .guarantee-card {
    background: #111;
    border: 1px solid rgba(151,191,13,0.2);
    border-radius: 20px; padding: 32px;
  }

  /* Calculator */
  .calc-card {
    background: #111;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px; padding: 40px;
  }
  .calc-label {
    display: block;
    color: rgba(255,255,255,0.45);
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 12px;
  }

  /* Org buttons */
  .org-btn {
    display: flex; flex-direction: column; align-items: flex-start;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 12px 16px;
    cursor: pointer; transition: all 0.2s; min-width: 110px;
  }
  .org-btn:hover { border-color: rgba(151,191,13,0.4); }
  .org-btn.active {
    background: rgba(151,191,13,0.12);
    border-color: #97BF0D;
  }
  .org-name { color: #fff; font-weight: 700; font-size: 0.88rem; }
  .org-fac  { color: rgba(255,255,255,0.4); font-size: 0.68rem; margin-top: 3px; }
  .org-btn.active .org-fac { color: #97BF0D; }

  /* Slider */
  .calc-slider {
    width: 100%; height: 6px;
    appearance: none; -webkit-appearance: none;
    background: rgba(255,255,255,0.1);
    border-radius: 4px; outline: none; cursor: pointer;
  }
  .calc-slider::-webkit-slider-thumb {
    appearance: none; -webkit-appearance: none;
    width: 26px; height: 26px; border-radius: 50%;
    background: #97BF0D; cursor: pointer;
    box-shadow: 0 0 0 4px rgba(151,191,13,0.2);
    transition: box-shadow 0.2s;
  }
  .calc-slider::-webkit-slider-thumb:hover {
    box-shadow: 0 0 0 10px rgba(151,191,13,0.12);
  }
  .calc-slider::-moz-range-thumb {
    width: 26px; height: 26px; border-radius: 50%;
    background: #97BF0D; cursor: pointer; border: none;
  }

  /* Level track */
  .level-track {
    background: rgba(255,255,255,0.06);
    border-radius: 8px; height: 30px;
    position: relative; overflow: hidden;
  }
  .level-fill {
    height: 100%;
    background: linear-gradient(90deg, rgba(151,191,13,0.25), #97BF0D);
    border-radius: 8px; transition: width 0.3s ease;
  }
  .level-labels {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: space-around;
  }
  .level-lbl {
    font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25); transition: color 0.3s;
    z-index: 1;
  }
  .active-lbl { color: #fff; }

  /* Result box */
  .result-box {
    background: rgba(151,191,13,0.06);
    border: 1px solid rgba(151,191,13,0.2);
    border-radius: 16px; padding: 28px;
    transition: all 0.3s;
  }

  /* Buy items */
  .buy-item {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.05);
    border-radius: 10px; padding: 8px 12px;
    transition: all 0.3s;
  }
  .buy-icon { font-size: 1rem; }
  .buy-text { color: rgba(255,255,255,0.7); font-size: 0.78rem; font-weight: 500; }

  /* Form */
  .fstep.hidden { display: none; }
  .fgroup { display: flex; flex-direction: column; gap: 6px; }
  .flabel { color: rgba(255,255,255,0.45); font-size: 0.78rem; font-weight: 600; }
  .finput {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 13px 16px;
    color: #fff; font-size: 1rem; outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%; font-family: inherit;
  }
  .finput:focus { border-color: #97BF0D; background: rgba(151,191,13,0.05); }
  .finput::placeholder { color: rgba(255,255,255,0.2); }
  textarea.finput { resize: vertical; }
  select.finput option { background: #1a1a1a; }

  /* Tailwind bg-white/4 workaround */
  .bg-white\/4  { background: rgba(255,255,255,0.04); }
  .bg-white\/8  { background: rgba(255,255,255,0.08); }
  .border-white\/8 { border-color: rgba(255,255,255,0.08); }

  @media (max-width: 640px) {
    .community-grid { grid-template-columns: repeat(2,1fr); }
    .community-img.tall { height: 190px; }
    .phone-mockup { width: 230px; height: 460px; }
    .calc-card { padding: 24px; }
  }
</style>


<!-- ────────────────────────────────────────────────────── SCRIPTS ── -->
<script>
  /* ── Page nav ─────────────────────────────────── */
  function goToPage(n) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const pg = document.getElementById('page-' + n);
    if (pg) { pg.classList.add('active'); window.scrollTo({ top: 0 }); }
    if (n === 2) { setTimeout(updateCalc, 100); }
  }

  /* ── UGC slider ───────────────────────────────── */
  let slide = 0;
  function goToSlide(i) {
    slide = i;
    const el = document.getElementById('ugc-slides');
    if (el) el.style.transform = `translateX(-${i * (100/3)}%)`;
    document.querySelectorAll('.ugc-dot').forEach((d, j) => d.classList.toggle('active', j === i));
  }
  setInterval(() => goToSlide((slide + 1) % 3), 3400);

  /* touch swipe */
  let tx = 0;
  document.addEventListener('DOMContentLoaded', () => {
    const sc = document.getElementById('ugc-screen');
    if (!sc) return;
    sc.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
    sc.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - tx;
      if (Math.abs(dx) > 40) goToSlide(dx < 0 ? Math.min(slide+1,2) : Math.max(slide-1,0));
    });
  });

  /* ── Calculator data ──────────────────────────── */
  const ORGS = [
    { id:'brk',  name:'BRK',       newcomer:4,  elite:7,  takeoff:550,  max:2750 },
    { id:'drk',  name:'DRK',       newcomer:5,  elite:8,  takeoff:450,  max:2250 },
    { id:'mhd',  name:'Malteser',  newcomer:6,  elite:9,  takeoff:400,  max:2000 },
    { id:'bn',   name:'BN Bayern', newcomer:7,  elite:11, takeoff:300,  max:1500 },
    { id:'bund', name:'BUND',      newcomer:9,  elite:13, takeoff:250,  max:1250 },
  ];
  let curOrg = ORGS[0]; // BRK als Standard

  /* render org buttons */
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('org-grid');
    if (!grid) return;
    ORGS.forEach((org, i) => {
      const btn = document.createElement('button');
      btn.className = 'org-btn' + (i === 0 ? ' active' : '');
      btn.innerHTML = `<span class="org-name">${org.name}</span><span class="org-fac">Faktor ${org.newcomer}–${org.elite}</span>`;
      btn.onclick = () => {
        document.querySelectorAll('.org-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        curOrg = org;
        updateCalc();
      };
      grid.appendChild(btn);
    });
    updateCalc();
  });

  function getFactor(org, eh) {
    if (eh <= org.takeoff) return org.newcomer;
    if (eh >= org.max)     return org.elite;
    return org.newcomer + (eh - org.takeoff) / (org.max - org.takeoff) * (org.elite - org.newcomer);
  }

  const BUYS = [
    { min: 300,  emoji:'🍕', text:'4 Wochen Essen & Ausgehen' },
    { min: 800,  emoji:'🎫', text:'Festival-Sommer komplett' },
    { min: 1200, emoji:'✈️', text:'1 Monat Backpacking' },
    { min: 1800, emoji:'🚴', text:'Neues Rennrad' },
    { min: 2400, emoji:'☕', text:'Siebträger-Maschine' },
    { min: 3000, emoji:'🌏', text:'2 Monate Südostasien' },
    { min: 3800, emoji:'🎓', text:'1 Semester Studiengebühren' },
    { min: 4500, emoji:'🏄', text:'Surf-Trip Bali + Unterkunft' },
  ];

  function fmt(n) { return Math.round(n).toLocaleString('de-DE') + ' €'; }

  function updateCalc() {
    const slider = document.getElementById('eh-slider');
    if (!slider) return;
    const eh     = parseInt(slider.value);
    const factor = getFactor(curOrg, eh);
    const gross  = eh * factor;
    const net    = gross * 0.8 + 200; // minus storno + anreisebonus

    /* display */
    document.getElementById('eh-display').textContent = eh + ' EH';
    document.getElementById('r-factor').textContent   = factor.toFixed(1);
    document.getElementById('r-gross').textContent    = fmt(gross);
    document.getElementById('r-net').textContent      = fmt(net);

    /* slider track */
    const pct = (eh / 900) * 100;
    slider.style.background = `linear-gradient(90deg,#97BF0D ${pct}%,rgba(255,255,255,0.1) ${pct}%)`;

    /* level fill */
    document.getElementById('level-fill').style.width = pct + '%';
    ['newcomer','pro','elite'].forEach(l => document.getElementById('lbl-'+l)?.classList.remove('active-lbl'));
    if      (eh >= curOrg.max)     document.getElementById('lbl-elite')?.classList.add('active-lbl');
    else if (eh >= curOrg.takeoff) document.getElementById('lbl-pro')?.classList.add('active-lbl');
    else                           document.getElementById('lbl-newcomer')?.classList.add('active-lbl');

    /* buy items */
    const buyGrid = document.getElementById('buy-grid');
    if (buyGrid) {
      const shown = BUYS.filter(b => net >= b.min);
      buyGrid.innerHTML = shown.length
        ? shown.map(b => `<div class="buy-item"><span class="buy-icon">${b.emoji}</span><span class="buy-text">${b.text}</span></div>`).join('')
        : '<p style="color:rgba(255,255,255,0.3);font-size:.85rem">Schiebe den Regler nach rechts …</p>';
    }
  }

  /* ── Form steps ───────────────────────────────── */
  function nextStep(n) {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-'+n)?.classList.remove('hidden');
    const pcts = { 1:33, 2:66, 3:100 };
    const p = pcts[n] || 33;
    const bar = document.getElementById('progress-bar');
    if (bar) bar.style.width = p + '%';
    const lbl = document.getElementById('step-label');
    if (lbl) lbl.textContent = 'Schritt ' + n + ' von 3';
    const pctEl = document.getElementById('step-pct');
    if (pctEl) pctEl.textContent = p + ' %';
  }

  function submitForm() {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-ok')?.classList.remove('hidden');
    const bar = document.getElementById('progress-bar');
    if (bar) bar.style.width = '100%';
  }

  /* globals for inline handlers */
  window.goToPage   = goToPage;
  window.goToSlide  = goToSlide;
  window.updateCalc = updateCalc;
  window.nextStep   = nextStep;
  window.submitForm = submitForm;
</script>

</Layout>
