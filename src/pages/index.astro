<script>
  /* ── UGC Video Carousel (single video, iOS-kompatibel) ── */
  (function(){
    var vid  = document.getElementById('ugc-video');
    var dots = Array.from(document.querySelectorAll('.ugc-dot'));
    var screen = vid && vid.parentElement;
    if (!vid || !screen) return;

    var VIDEOS = [
      { src: '/videos/ugc-hero.mp4',  poster: '/videos/ugc-poster.jpg' },
      { src: '/videos/ugc-9.mp4',     poster: '/videos/ugc-9-poster.jpg' },
      { src: '/videos/ugc-cash.mp4',  poster: '/videos/ugc-cash-poster.jpg' }
    ];

    var cur = 0, started = false;
    var startX = 0, startY = 0, dragging = false;

    function goTo(idx) {
      cur = ((idx % VIDEOS.length) + VIDEOS.length) % VIDEOS.length;
      dots.forEach(function(d,i){ d.style.opacity = i===cur ? '1' : '0.4'; });
      if (!started) return;
      // Fade out, swap source, fade in
      vid.style.opacity = '0';
      vid.pause();
      setTimeout(function(){
        vid.poster = VIDEOS[cur].poster;
        vid.src    = VIDEOS[cur].src;
        vid.load();
        vid.style.opacity = '1';
        vid.play().catch(function(){});
      }, 180);
    }

    vid.addEventListener('ended', function(){ goTo(cur + 1); });

    // Dots
    dots.forEach(function(d,i){ d.addEventListener('click', function(){ goTo(i); }); });

    // First tap — play with audio
    window.ugcStart = function() {
      var overlay = document.getElementById('ugc-play-overlay');
      if (overlay) overlay.style.display = 'none';
      started = true;
      vid.play().catch(function(){});
    };

    // Touch swipe
    screen.addEventListener('touchstart', function(e){
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      dragging = true;
    }, { passive: true });

    screen.addEventListener('touchend', function(e){
      if (!dragging) return; dragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      var dy = e.changedTouches[0].clientY - startY;
      if (Math.abs(dx) > 20 && Math.abs(dx) > Math.abs(dy) * 0.8) {
        goTo(dx < 0 ? cur + 1 : cur - 1);
      }
    }, { passive: true });

    // Mouse drag (desktop)
    screen.addEventListener('mousedown', function(e){ startX = e.clientX; dragging = true; });
    screen.addEventListener('mouseup', function(e){
      if (!dragging) return; dragging = false;
      var dx = e.clientX - startX;
      if (Math.abs(dx) > 30) goTo(dx < 0 ? cur + 1 : cur - 1);
    });
  })();

  /* ── Page nav ─────────────────── */
  function goToPage(n) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const pg = document.getElementById('page-' + n);
    if (pg) { pg.classList.add('active'); window.scrollTo({ top:0 }); }
    if (n === 2) setTimeout(initChart, 80);
  }

  /* ── UGC swiper ───────────────── */
  let slide = 0;
  function goToSlide(i) {
    slide = i;
    const el = document.getElementById('ugc-slides');
    if (el) el.style.transform = `translateX(-${i*(100/3)}%)`;
    document.querySelectorAll('.ugc-dot').forEach((d,j) => d.classList.toggle('active', j===i));
  }
  setInterval(() => goToSlide((slide+1)%3), 3400);
  let tx0 = 0;
  document.addEventListener('DOMContentLoaded', () => {
    const sc = document.getElementById('ugc-screen');
    if (!sc) return;
    sc.addEventListener('touchstart', e => { tx0 = e.touches[0].clientX; }, {passive:true});
    sc.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - tx0;
      if (Math.abs(dx)>40) goToSlide(dx<0 ? Math.min(slide+1,2) : Math.max(slide-1,0));
    });
  });

  /* ── Review slider ────────────── */
  const TOTAL_REVIEWS = 6;
  let revIdx = 0;
  function revMove(dir) {
    revIdx = Math.max(0, Math.min(TOTAL_REVIEWS - 1, revIdx + dir));
    const track = document.getElementById('reviews-track');
    if (!track) return;
    // Offset based on actual slide pixel width + gap — works on both mobile and desktop
    const slide = track.querySelector('.review-slide');
    const gap = 16; // matches CSS gap
    const slideW = slide ? slide.offsetWidth + gap : 0;
    track.style.transform = `translateX(-${revIdx * slideW}px)`;
    document.querySelectorAll('.rev-dot').forEach((d,i) => d.classList.toggle('active', i===revIdx));
  }

  // Touch swipe for reviews
  document.addEventListener('DOMContentLoaded', () => {
    const dotsEl = document.getElementById('rev-dots');
    if (dotsEl) {
      for (let i=0; i<TOTAL_REVIEWS; i++) {
        const d = document.createElement('button');
        d.className = 'rev-dot' + (i===0?' active':'');
        d.onclick = () => { revIdx = i - 1; revMove(1); };
        dotsEl.appendChild(d);
      }
    }
    const wrap = document.querySelector('.reviews-slider-wrap');
    if (!wrap) return;
    let sx = 0;
    wrap.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
    wrap.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 30) revMove(dx < 0 ? 1 : -1);
    }, { passive: true });
  });

  /* ── BRK (Beispiel) ──────────── */
  const curOrg = { newcomer:4, elite:7, takeoff:550, max:2750 };
  // MAX_EH chosen so right edge ≈ 5.500 €: 1320 EH → factor≈5.09 → net≈5.500
  const MAX_EH = 1320;
  // Ø position: 870 EH → net ≈ 3.300 €
  const AVG_EH = 870;

  function getFactor(org, eh) {
    if (eh <= org.takeoff) return org.newcomer;
    if (eh >= org.max)     return org.elite;
    return org.newcomer + (eh - org.takeoff)/(org.max - org.takeoff)*(org.elite - org.newcomer);
  }
  function getNet(org, eh) { return eh * getFactor(org, eh) * 0.8 + 200; }
  function fmt(n) { return Math.round(n).toLocaleString('de-DE') + ' €'; }

  const PHOTOS = [
    { min:0,    url:'https://images.unsplash.com/photo-1527786356703-4b100091cd2c?w=600&q=80', emoji:'🗺️', text:'Bewege den Cursor über die Kurve' },
    { min:400,  url:'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=600&q=80', emoji:'🎒', text:'Wochenend-Trip finanziert' },
    { min:900,  url:'https://images.unsplash.com/photo-1493676304819-0d7a8d026dcf?w=600&q=80', emoji:'🎪', text:'Festival-Sommer komplett' },
    { min:1600, url:'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=600&q=80', emoji:'✈️', text:'1 Monat Backpacking' },
    { min:2400, url:'https://images.unsplash.com/photo-1485965120184-e220f721d03e?w=600&q=80', emoji:'🚴', text:'Neues Rennrad' },
    { min:3200, url:'/images/siebtraeger.jpg', emoji:'☕', text:'Siebträgermaschine' },
    { min:4200, url:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80', emoji:'🌏', text:'3 Monate Südostasien' },
  ];

  function updatePhoto(net) {
    let chosen = PHOTOS[0];
    PHOTOS.forEach(p => { if (net >= p.min) chosen = p; });
    // Desktop photo
    const img = document.getElementById('context-photo');
    if (img && img.getAttribute('data-src') !== chosen.url) {
      img.setAttribute('data-src', chosen.url);
      img.style.opacity = '0';
      setTimeout(() => { img.src = chosen.url; img.style.opacity = '1'; }, 300);
    }
    const cap = document.getElementById('caption-text');
    const emo = document.getElementById('caption-emoji');
    if (cap) cap.textContent = chosen.text;
    if (emo) emo.textContent = chosen.emoji;
    // Mobile strip photo
    const imgM = document.getElementById('context-photo-mobile');
    if (imgM && imgM.getAttribute('data-src') !== chosen.url) {
      imgM.setAttribute('data-src', chosen.url);
      imgM.style.opacity = '0';
      setTimeout(() => { imgM.src = chosen.url; imgM.style.opacity = '1'; }, 300);
    }
    const capM = document.getElementById('caption-text-m');
    const emoM = document.getElementById('caption-emoji-m');
    if (capM) capM.textContent = chosen.text;
    if (emoM) emoM.textContent = chosen.emoji;
  }

  /* ── Chart ───────────────────── */
  let chartInited = false;
  function initChart() {
    if (!chartInited) {
      chartInited = true;
      const wrap = document.getElementById('chart-wrap');
      if (wrap) {
        wrap.addEventListener('mousemove', onChartMoveWithStop);
        wrap.addEventListener('mouseleave', onChartLeave);
        wrap.addEventListener('touchmove', e => {
          e.preventDefault();
          onChartMoveWithStop({ clientX: e.touches[0].clientX, _wrap: wrap });
        }, { passive: false });
        wrap.addEventListener('touchstart', e => {
          onChartMoveWithStop({ clientX: e.touches[0].clientX, _wrap: wrap });
        }, { passive: true });
        wrap.addEventListener('touchend', onChartLeave, { passive: true });
      }
    }
    redrawChart();
    setTimeout(runChartIntro, 600);
  }

  // Non-linear x-axis: center (50%) = AVG_EH = 870 EH = Ø 3.300€
  // Forward:  pct → eh  = MAX_EH * pct^0.601
  // Inverse:  eh  → pct = (eh/MAX_EH)^1.664  → x = W * pct
  function ehToX(eh, W) { return W * Math.pow(eh / MAX_EH, 1.664); }
  // Y-axis based on net earnings (0 to MAX_NET) for intuitive display
  const MAX_NET = 5700; // slightly above 5.500 for visual breathing room
  function netToY(net, H) { return H - (net / MAX_NET) * H * 0.88 - H * 0.06; }

  function redrawChart() {
    const svg = document.getElementById('provision-chart');
    if (!svg) return;
    const W = 600, H = 260, org = curOrg;
    const pts = [];
    for (let eh = 0; eh <= MAX_EH; eh += 10) {
      const net = getNet(org, eh);
      pts.push({ x: ehToX(eh,W), y: netToY(net,H) });
    }
    const d = pts.map((p,i) => (i===0?`M${p.x.toFixed(1)},${p.y.toFixed(1)}`:`L${p.x.toFixed(1)},${p.y.toFixed(1)}`)).join(' ');
    document.getElementById('chart-curve').setAttribute('d', d);
    document.getElementById('chart-area').setAttribute('d', d + ` L${W},${H} L0,${H} Z`);

    /* zones */
    const tX = ehToX(org.takeoff, W), mX = ehToX(Math.min(org.max,MAX_EH), W);
    document.getElementById('chart-bg').innerHTML =
      `<rect x="0" y="0" width="${tX}" height="${H}" fill="#E0F4FF" opacity=".5"/>` +
      `<rect x="${tX}" y="0" width="${mX-tX}" height="${H}" fill="#FFE0F0" opacity=".35"/>` +
      `<rect x="${mX}" y="0" width="${W-mX}" height="${H}" fill="#F0FFE0" opacity=".4"/>`;

    /* grid */
    let gl = '';
    for (let i=1;i<5;i++) gl += `<line x1="0" y1="${H/5*i}" x2="${W}" y2="${H/5*i}" stroke="rgba(27,42,74,0.06)" stroke-width="1"/>`;
    document.getElementById('chart-grid').innerHTML = gl;

    /* takeoff marker */
    const mkr = document.getElementById('takeoff-marker');
    if (mkr) mkr.style.left = (Math.pow(org.takeoff/MAX_EH, 1.664)*100) + '%';

    /* Ø 3.300€ marker at AVG_EH — use non-linear mapping */
    const avgX = ehToX(AVG_EH, W);
    const avgLine = document.getElementById('avg-line');
    const avgBg   = document.getElementById('avg-badge-bg');
    const avgTxt  = document.getElementById('avg-badge-txt');
    if (avgLine) { avgLine.setAttribute('x1', avgX); avgLine.setAttribute('x2', avgX); }
    if (avgBg)   { avgBg.setAttribute('x', avgX + 5); }
    if (avgTxt)  { avgTxt.setAttribute('x', avgX + 9); }

    updateDisplay(AVG_EH);
  }

  function onChartMove(e) {
    const wrap = e._wrap || document.getElementById('chart-wrap');
    if (!wrap) return;
    const rect = wrap.getBoundingClientRect();
    const pct  = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    const eh   = Math.round(MAX_EH * Math.pow(pct, 0.601) / 10) * 10;
    const W=600, H=260, org=curOrg;
    const svgX = pct * W;
    const f    = getFactor(org, eh);
    const net  = getNet(org, eh);
    const svgY = netToY(net, H);

    const line = document.getElementById('cursor-line');
    const dot  = document.getElementById('cursor-dot');
    if (line) { line.setAttribute('x1',svgX); line.setAttribute('x2',svgX); line.style.opacity='1'; }
    if (dot)  { dot.setAttribute('cx',svgX); dot.setAttribute('cy',svgY); dot.style.opacity='1'; }

    const tt = document.getElementById('chart-tooltip');
    if (tt) {
      document.getElementById('tt-eh').textContent     = eh + ' EH';
      document.getElementById('tt-factor').textContent = 'Faktor ' + f.toFixed(1);
      document.getElementById('tt-money').textContent  = fmt(net);
      // keep tooltip inside bounds
      const ttLeft = Math.min(pct * rect.width, rect.width - 110);
      tt.style.left = Math.max(10, ttLeft) + 'px';
      const dotY = (svgY / H) * rect.height;
      tt.style.top = dotY + 'px';
      // flip below dot if tooltip would overlap photo strip (top ~90px of chart area)
      if (dotY < 90) {
        tt.classList.add('flip');
      } else {
        tt.classList.remove('flip');
      }
      tt.style.opacity = '1';
      updatePhoto(net);
    }
    updateDisplay(eh);
  }

  function onChartLeave() {
    ['cursor-line','cursor-dot'].forEach(id => { const el=document.getElementById(id); if(el) el.style.opacity='0'; });
    const tt = document.getElementById('chart-tooltip'); if(tt) tt.style.opacity='0';
  }

  /* ── Chart intro animation ────── */
  let chartAnimDone = false;
  let chartAnimRaf  = null;

  function runChartIntro() {
    if (chartAnimDone) return;
    const wrap = document.getElementById('chart-wrap');
    if (!wrap) return;
    const W = 600, H = 260;

    // Keyframes: 0→center→0→center (2 sweeps so user clearly sees it's interactive)
    // Each sweep: 1200ms, pause 200ms at peaks
    const SWEEP = 1200, PAUSE = 300;
    const SEQ = [
      { from: 0, to: 0.5, dur: SWEEP },
      { from: 0.5, to: 0.5, dur: PAUSE },  // pause at center
      { from: 0.5, to: 0.05, dur: 700 },   // sweep back (faster)
      { from: 0.05, to: 0.05, dur: PAUSE },
      { from: 0.05, to: 0.5, dur: SWEEP },  // sweep to center again
      { from: 0.5, to: 0.5, dur: PAUSE },
    ];
    const totalDur = SEQ.reduce((s, k) => s + k.dur, 0);
    const start = performance.now();

    function easeInOut(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

    function getPct(elapsed) {
      let acc = 0;
      for (const k of SEQ) {
        if (elapsed <= acc + k.dur) {
          const localT = (elapsed - acc) / k.dur;
          const e = easeInOut(Math.max(0, Math.min(1, localT)));
          return k.from + (k.to - k.from) * e;
        }
        acc += k.dur;
      }
      return 0.5; // end at center
    }

    function frame(now) {
      if (chartAnimDone) return;
      const elapsed = now - start;
      const pct = getPct(elapsed);
      const eh = Math.round(MAX_EH * Math.pow(Math.max(0.0001, pct), 0.601) / 10) * 10;
      const svgX = pct * W;
      const net  = getNet(curOrg, eh);
      const svgY = netToY(net, H);

      const line = document.getElementById('cursor-line');
      const dot  = document.getElementById('cursor-dot');
      if (line) { line.setAttribute('x1',svgX); line.setAttribute('x2',svgX); line.style.opacity='1'; }
      if (dot)  { dot.setAttribute('cx',svgX); dot.setAttribute('cy',svgY); dot.style.opacity='1'; }
      updateDisplay(eh);

      if (elapsed < totalDur) {
        chartAnimRaf = requestAnimationFrame(frame);
      } else {
        // finished – keep cursor at center, show hint
        const hint = document.getElementById('chart-hint');
        if (hint) { hint.style.opacity='1'; setTimeout(()=>{ hint.style.opacity='0'; }, 2500); }
      }
    }
    chartAnimRaf = requestAnimationFrame(frame);
  }

  function onChartMoveWithStop(e) {
    if (!chartAnimDone) {
      chartAnimDone = true;
      if (chartAnimRaf) { cancelAnimationFrame(chartAnimRaf); chartAnimRaf = null; }
      const hint = document.getElementById('chart-hint');
      if (hint) hint.style.opacity = '0';
    }
    onChartMove(e);
  }

  function updateDisplay(eh) {
    const org=curOrg, f=getFactor(org,eh), gross=eh*f, net=gross*0.8+200;
    const gEl=document.getElementById('r-gross'), nEl=document.getElementById('r-net');
    if(gEl) gEl.textContent=fmt(gross);
    if(nEl) nEl.textContent=fmt(net);
  }

  /* ── Form ────────────────────── */
  function nextStep(n) {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-'+n)?.classList.remove('hidden');
    const p={1:33,2:66,3:100}[n]||33;
    const bar=document.getElementById('progress-bar'); if(bar) bar.style.width=p+'%';
    document.getElementById('step-label').textContent='Schritt '+n+' von 3';
    document.getElementById('step-pct').textContent=p+' %';
  }
  function submitForm() {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-ok')?.classList.remove('hidden');
    document.getElementById('progress-bar').style.width='100%';
  }

  /* ── NGO slider (mobile, 2 per view) ── */
  let ngoIdx = 0;
  const NGO_TOTAL = 4, NGO_PER = 2;
  setInterval(() => {
    ngoIdx = (ngoIdx + NGO_PER) % NGO_TOTAL;
    const t = document.getElementById('ngo-track');
    if (t) t.style.transform = `translateX(-${ngoIdx * 50}%)`;
  }, 2800);

  window.goToPage=goToPage; window.goToSlide=goToSlide; window.nextStep=nextStep;
  window.submitForm=submitForm; window.revMove=revMove;
</script>

</Layout>
