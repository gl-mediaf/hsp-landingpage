---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="hsp – Der Ferienjob mit dem gewissen Etwas"
  description="Mach Ø 3.300 € in 4 Wochen. Für den guten Zweck von Tür zu Tür. Jetzt anfragen."
>

<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

<div id="app">

  <!-- ══════════════════════════════════════════════
       PAGE 1
  ══════════════════════════════════════════════════ -->
  <div id="page-1" class="page active">

    <!-- NAV -->
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center px-5 py-2 nav-bar">
      <img src="/images/hsp-logo.png" alt="hsp" class="hsp-logo-img" />
    </nav>

    <!-- HERO -->
    <section class="relative overflow-hidden hero-section">
      <div class="absolute inset-0 z-0">
        <img
          src="/images/hero-bild.jpg"
          alt="hsp Fundraiserin"
          class="w-full h-full object-cover" style="object-position: center 8%"
          onerror="this.src='https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/83f030975e710fa51e73d412a5b6b838.png'"
        />
        <div class="absolute inset-0" style="background:linear-gradient(to top,#1B2A4A 0%,rgba(27,42,74,0.7) 40%,rgba(27,42,74,0.2) 100%)"></div>
      </div>
      <div class="relative z-10 px-5 md:px-16 hero-content max-w-4xl">
        <h1 class="hd text-white mb-4" style="font-size:clamp(2.6rem,11vw,6.5rem);line-height:0.92">
          3 Monate<br />
          <span style="color:#97BF0D">arbeiten.</span><br />
          9 Monate<br />
          reisen.
        </h1>
        <!-- Ø earnings highlight -->
        <div class="inline-flex items-baseline gap-2 mb-4">
          <span class="hd text-white" style="font-size:clamp(1.6rem,5vw,2.2rem)">Ø 3.300 €</span>
          <span style="color:#97BF0D;font-weight:800;font-size:clamp(0.85rem,2.5vw,1rem)">in 4 Wochen</span>
        </div>
        <p class="text-white/70 font-bold leading-relaxed" style="font-size:clamp(0.9rem,2.5vw,1.1rem);max-width:420px">
          Für den guten Zweck von Tür zu Tür unterwegs –
          und dabei richtig gutes Geld machen.
        </p>
        <div class="mt-5 hidden md:flex items-center gap-3 text-white/40 text-sm font-semibold">
          <div class="scroll-dot-wrap"><span class="scroll-dot"></span></div>
          Scroll
        </div>
      </div>
    </section>

    <!-- NGO LOGOS BAR -->
    <section class="bg-[#1B2A4A] py-5 px-5">
      <div class="max-w-5xl mx-auto">
        <p class="text-white/60 text-xs font-bold uppercase tracking-widest mb-5 text-center" style="letter-spacing:0.18em">Unterwegs für diese Organisationen</p>
        <!-- Desktop: alle 4 nebeneinander -->
        <div class="hidden md:flex items-center justify-center gap-6">
          <div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/a1fb69a2c913e2039dbcb6b948598f9f.png" alt="Malteser" class="ngo-logo-color" /></div>
          <div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/073d6a9102a1cf494cf6447eda00d271.png" alt="BUND" class="ngo-logo-color" /></div>
          <div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/88c9cd2ef210ff7229bc1e488c3b8fbb.png" alt="BRK" class="ngo-logo-color" /></div>
          <div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/9d4bdf70be465070a020c846b1279d1c.png" alt="BN Bayern" class="ngo-logo-color" /></div>
        </div>
        <!-- Mobile: 2er-Slider -->
        <div class="md:hidden ngo-slider-wrap">
          <div class="ngo-slider-track" id="ngo-track">
            <div class="ngo-slide"><div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/a1fb69a2c913e2039dbcb6b948598f9f.png" alt="Malteser" class="ngo-logo-color" /></div></div>
            <div class="ngo-slide"><div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/073d6a9102a1cf494cf6447eda00d271.png" alt="BUND" class="ngo-logo-color" /></div></div>
            <div class="ngo-slide"><div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/88c9cd2ef210ff7229bc1e488c3b8fbb.png" alt="BRK" class="ngo-logo-color" /></div></div>
            <div class="ngo-slide"><div class="ngo-card"><img src="https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/9d4bdf70be465070a020c846b1279d1c.png" alt="BN Bayern" class="ngo-logo-color" /></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- WAS DU MACHST -->
    <section id="was-du-machst" class="bg-white py-10 md:py-16 px-5">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h2 class="hd text-[#1B2A4A]" style="font-size:clamp(2rem,6vw,3.25rem);line-height:1.0">
            Du überzeugst Menschen<br />für den <span style="color:#97BF0D">guten Zweck.</span>
          </h2>
          <p class="text-[#1B2A4A]/65 text-base md:text-lg leading-relaxed mt-5 mb-7 font-semibold">
            Als Fundraiser bist du für renommierte Hilfsorganisationen von Tür zu Tür
            unterwegs – und begeisterst Menschen im direkten Gespräch für fördernde
            Mitgliedschaften. Nicht einfach. Genau deshalb machst du richtig gutes Geld.
          </p>
          <ul class="space-y-3">
            {[
              'Entwickel dich rhetorisch weiter',
              'Arbeite für einen guten Zweck',
              'Gemeinsam mit deinen Freunden',
            ].map(item => (
              <li class="flex items-start gap-3 text-[#1B2A4A]/75 font-semibold text-sm md:text-base">
                <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-white text-xs font-black" style="background:#97BF0D">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img src="/images/pr-hero.jpg" alt="Fundraiser im Gespräch" class="w-full rounded-3xl object-cover shadow-xl" style="aspect-ratio:4/5" />
          <div class="absolute -bottom-4 -left-4 shadow-xl flex flex-col items-center justify-center" style="background:#97BF0D;border-radius:50%;width:130px;height:130px">
            <p class="hd text-white" style="font-size:1.5rem;line-height:1.1">Ø 3.300 €</p>
            <p class="text-white/80 text-sm font-bold">in 4 Wochen</p>
          </div>
        </div>
      </div>

    </section>

    <!-- PHONE MOCKUP – UGC -->
    <section class="bg-[#F0F7FF] py-10 md:py-16 px-5 overflow-hidden">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="md:w-1/2">
          <h2 class="hd text-[#1B2A4A]" style="font-size:clamp(2rem,6vw,3rem);line-height:1.0">
            Schau rein –<br /><span style="color:#E5007D">echter Alltag.</span>
          </h2>
          <p class="text-[#1B2A4A]/65 text-base md:text-lg leading-relaxed mt-5 font-semibold">
            Kein Büro, kein 9-to-5. Du bist draußen, im Gespräch,
            mit deiner Crew unterwegs – und wächst mit jeder Tür.
          </p>
        </div>
        <div class="md:w-1/2 flex justify-center">
          <div class="phone-mockup">
            <div class="phone-notch"></div>
            <div class="phone-screen" style="overflow:hidden;position:relative;background:#000">
              <!-- Single video element — iOS-kompatibel -->
              <video id="ugc-video" playsinline
                poster="/videos/ugc-poster.jpg"
                style="width:100%;height:100%;object-fit:cover;display:block;transition:opacity 0.2s">
                <source src="/videos/ugc-hero.mp4" type="video/mp4" />
              </video>
              <!-- Dots -->
              <div id="ugc-dots" style="position:absolute;bottom:10px;left:0;right:0;display:flex;justify-content:center;gap:8px;z-index:3">
                <span class="ugc-dot" style="width:10px;height:10px;border-radius:50%;background:#fff;opacity:1;transition:opacity .2s;cursor:pointer"></span>
                <span class="ugc-dot" style="width:10px;height:10px;border-radius:50%;background:#fff;opacity:0.4;transition:opacity .2s;cursor:pointer"></span>
                <span class="ugc-dot" style="width:10px;height:10px;border-radius:50%;background:#fff;opacity:0.4;transition:opacity .2s;cursor:pointer"></span>
              </div>
              <!-- Play overlay -->
              <div id="ugc-play-overlay" style="position:absolute;inset:0;z-index:4;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,0.25);cursor:pointer" onclick="ugcStart()">
                <div style="width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,0.92);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.3)">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#1B2A4A"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <span style="color:#fff;font-size:0.7rem;font-weight:800;margin-top:8px;letter-spacing:0.04em;text-shadow:0 1px 4px rgba(0,0,0,0.5)">TIPPE ZUM ABSPIELEN</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMUNITY -->
    <section id="community" class="bg-white py-10 md:py-16 px-5">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="hd text-[#1B2A4A]" style="font-size:clamp(2rem,6vw,3rem);line-height:1.0">
            Deine Community<br /><span style="color:#E5007D">wartet auf dich.</span>
          </h2>
          <p class="text-[#1B2A4A]/55 text-base md:text-lg mt-3 max-w-lg mx-auto font-semibold">
            Neue Freundschaften, unvergessliche Erlebnisse, echte Verbindungen.
          </p>
        </div>
        <div class="community-grid">
          <img src="/images/pr-1.jpg"   alt="" class="community-img tall" />
          <img src="/images/8-opt.jpg"  alt="" class="community-img" />
          <img src="/images/10-opt.jpg" alt="" class="community-img" />
          <img src="/images/5-opt.jpg"  alt="" class="community-img tall" />
          <img src="/images/pr-2.jpg"   alt="" class="community-img" />
          <img src="/images/pr-3.jpg"   alt="" class="community-img" />
        </div>
      </div>
    </section>

    <!-- GOOGLE REVIEWS SLIDER -->
    <section class="bg-[#1B2A4A] py-10 md:py-16 px-5 overflow-hidden">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="hd text-white" style="font-size:clamp(2rem,6vw,3rem);line-height:1.0">
            Was andere sagen.
          </h2>
          <div class="flex items-center justify-center gap-2 mt-3">
            <span class="text-yellow-400 text-xl">★★★★★</span>
            <span class="hd text-white" style="font-size:1.4rem">4.8</span>
            <span class="text-white/40 text-sm font-semibold">auf Google</span>
          </div>
        </div>

        <!-- Image slider -->
        <div class="reviews-slider-wrap">
          <div class="reviews-track" id="reviews-track">
            {[
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/0792d43e1c825562988748393508c1b5.png',
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/dac8c3f2ef50bf4f8d1d47a3e80cf14e.png',
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/d2c0b0e3ad7ceed17618c4c1178f6b6b.png',
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/ff88471118fbb49a9fe62493d87ee8e2.png',
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/ffd8e294bb250c2a760960795324b0e9.png',
              'https://static.funnelcockpit.com/upload/LLmaqMFur7JxCm9fW/0a611f8ed1e9324a436d4b4394587988.png',
            ].map(url => (
              <div class="review-slide">
                <img src={url} alt="Google Bewertung" class="review-img" />
              </div>
            ))}
          </div>
          <!-- prev/next -->
          <button class="rev-btn rev-prev" id="rev-prev" onclick="revMove(-1)">‹</button>
          <button class="rev-btn rev-next" id="rev-next" onclick="revMove(1)">›</button>
        </div>

        <!-- dots -->
        <div class="flex justify-center gap-2 mt-6" id="rev-dots"></div>

      </div>
    </section>

    <!-- CTA TO PAGE 2 -->
    <section class="py-12 md:py-20 px-5 text-center" style="background:#97BF0D">
      <h2 class="hd text-white max-w-xl mx-auto" style="font-size:clamp(2rem,6vw,3rem)">
        Was ist eigentlich<br />für dich drinnen?
      </h2>
      <p class="text-white/80 text-base md:text-lg mt-4 mb-8 max-w-md mx-auto font-semibold">
        Kein fixes Gehalt – du bestimmst, wie viel du machst. Rechne es selbst nach.
      </p>
      <button onclick="goToPage(2)" class="btn-dark text-base px-8 py-4">
        Rechne deinen Einsatz durch →
      </button>
    </section>

  </div><!-- /page-1 -->


  <!-- ══════════════════════════════════════════════
       PAGE 2 — GELD MACHEN + RECHNER
  ══════════════════════════════════════════════════ -->
  <div id="page-2" class="page">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center px-5 py-2 nav-bar">
      <img src="/images/hsp-logo.png" alt="hsp" class="hsp-logo-img" />
    </nav>

    <!-- Mindestgarantie -->
    <section class="bg-white pt-24 pb-14 px-5">
      <div class="max-w-5xl mx-auto">
        <h2 class="hd text-[#1B2A4A] text-center mb-3" style="font-size:clamp(2rem,6vw,3rem)">
          Dein Geld. <span style="color:#97BF0D">Dein Einsatz.</span>
        </h2>
        <p class="text-[#1B2A4A]/55 text-base md:text-lg text-center max-w-xl mx-auto mb-12 font-semibold">
          Du wirst nach Provision bezahlt. Je mehr du begeisterst, desto mehr machst du.
          Als Sicherheitsnetz gibt's eine garantierte Basis.
        </p>
        <div class="guarantee-card">
          <p class="text-[#1B2A4A]/40 text-xs font-bold uppercase tracking-widest mb-2">Garantierte Mindestprovision</p>
          <p class="hd" style="color:#97BF0D;font-size:3.5rem;line-height:1">2.400 €</p>
          <p class="text-[#1B2A4A]/50 mt-1 mb-5 text-sm font-semibold">in 4 Wochen</p>
          <div class="flex items-center gap-2 mt-2">
            <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background:#97BF0D"></span>
            <span class="text-[#1B2A4A]/60 text-sm font-semibold">+ <strong class="text-[#1B2A4A]">200 € Anreisebonus</strong></span>
          </div>
        </div>
      </div>
    </section>

    <!-- RECHNER -->
    <section class="bg-[#F0F7FF] py-10 md:py-14 px-5">
      <div class="max-w-5xl mx-auto">
        <h2 class="hd text-[#1B2A4A] text-center mb-3" style="font-size:clamp(2rem,6vw,3rem)">
          Rechne deinen <span style="color:#E5007D">Einsatz durch.</span>
        </h2>


        <!-- Chart + Photo: single card on mobile, split on desktop -->
        <div class="calc-main-grid">

          <!-- LEFT: curve -->
          <div class="chart-panel">
            <div class="chart-wrap" id="chart-wrap">
              <svg id="provision-chart" viewBox="0 0 600 260" preserveAspectRatio="none" style="width:100%;height:100%;display:block;cursor:crosshair">
                <defs>
                  <linearGradient id="curveGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#E5007D"/>
                    <stop offset="100%" stop-color="#E5007D" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <g id="chart-bg"></g>
                <g id="chart-grid"></g>
                <!-- Y-axis week labels -->
                <text x="6" y="248" font-size="13" font-weight="800" fill="rgba(27,42,74,0.6)" font-family="Nunito, sans-serif">Woche 1</text>
                <text x="6" y="187" font-size="13" font-weight="800" fill="rgba(27,42,74,0.6)" font-family="Nunito, sans-serif">Woche 2</text>
                <text x="6" y="124" font-size="13" font-weight="800" fill="rgba(27,42,74,0.6)" font-family="Nunito, sans-serif">Woche 3</text>
                <text x="6" y="62"  font-size="13" font-weight="800" fill="rgba(27,42,74,0.6)" font-family="Nunito, sans-serif">Woche 4</text>
                <path id="chart-area" fill="url(#curveGrad)" opacity="0.25"/>
                <path id="chart-curve" fill="none" stroke="#E5007D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Ø 3.300€ marker (dashed line only, no badge) -->
                <line id="avg-line" x1="0" y1="0" x2="0" y2="260" stroke="#97BF0D" stroke-width="1.5" stroke-dasharray="5,4"/>
                <line id="cursor-line" x1="0" y1="0" x2="0" y2="260" stroke="#1B2A4A" stroke-width="1.5" stroke-dasharray="4,3" opacity="0"/>
                <circle id="cursor-dot" r="6" fill="#E5007D" stroke="#fff" stroke-width="2" opacity="0"/>
              </svg>
              <div id="chart-tooltip" class="chart-tooltip" style="opacity:0;pointer-events:none">
                <p id="tt-eh" class="tt-small"></p>
                <p id="tt-factor" class="tt-mid"></p>
                <p id="tt-money" class="tt-big"></p>
              </div>
              <div class="takeoff-marker" id="takeoff-marker">
                <div style="position:absolute;top:0;bottom:0;width:1px;border-left:1px dashed rgba(27,42,74,0.25)"></div>
              </div>
            </div>
            <div class="flex justify-between text-xs font-bold text-[#1B2A4A]/35 mt-1">
              <span>0 €</span>
              <span>Ø 3.300 € nach 4 Wochen</span>
              <span>~5.500 €</span>
            </div>
            <div id="chart-hint" style="text-align:center;font-size:0.72rem;font-weight:700;color:rgba(229,0,125,0.6);margin-top:4px;opacity:0;transition:opacity 0.4s;pointer-events:none">
              ← Schiebe über die Kurve →
            </div>
            <!-- Mobile photo strip — above chart on mobile via CSS order -->
            <div class="mobile-photo-strip" style="order:-1">
              <img id="context-photo-mobile" src="https://images.unsplash.com/photo-1527786356703-4b100091cd2c?w=600&q=80" alt="" />
              <div class="mobile-photo-cap">
                <span id="caption-emoji-m">🗺️</span>
                <span id="caption-text-m">Schiebe über die Kurve</span>
              </div>
            </div>
            <!-- Stats: nur Dein Geld -->
            <div class="mt-4">
              <div class="stat-box" style="border-top:3px solid #E5007D">
                <p class="stat-label">Dein Geld</p>
                <p class="hd stat-val" id="r-net" style="color:#E5007D">–</p>
              </div>
            </div>
          </div>

          <!-- RIGHT: photo (desktop only) -->
          <div class="photo-panel">
            <img id="context-photo" src="https://images.unsplash.com/photo-1527786356703-4b100091cd2c?w=600&q=80" alt="" class="context-img" />
            <div class="photo-caption">
              <span class="caption-emoji" id="caption-emoji">🗺️</span>
              <span class="caption-text" id="caption-text">Bewege den Cursor über die Kurve</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 md:py-20 px-5 text-center" style="background:#E5007D">
      <h2 class="hd text-white max-w-xl mx-auto" style="font-size:clamp(2rem,6vw,3rem)">
        Klingt gut?<br />Dann frag jetzt an.
      </h2>
      <p class="text-white/80 text-base md:text-lg mt-4 mb-8 font-semibold">Wir melden uns innerhalb von 24–48 Stunden bei dir!</p>
      <button onclick="goToPage(3)" class="btn-light px-8 py-4">Jetzt anfragen →</button>
    </section>

  </div><!-- /page-2 -->


  <!-- ══════════════════════════════════════════════
       PAGE 3 — FORM
  ══════════════════════════════════════════════════ -->
  <div id="page-3" class="page">
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center px-5 py-2 nav-bar">
      <img src="/images/hsp-logo.png" alt="hsp" class="hsp-logo-img" />
    </nav>
    <section class="min-h-screen bg-white flex items-center justify-center px-5 pt-24 pb-12">
      <div class="w-full max-w-md">
        <div class="mb-8">
          <div class="flex justify-between text-xs text-[#1B2A4A]/40 font-bold mb-2">
            <span id="step-label">Schritt 1 von 3</span>
            <span id="step-pct">33 %</span>
          </div>
          <div class="h-2 rounded-full overflow-hidden" style="background:rgba(27,42,74,0.1)">
            <div class="h-full rounded-full transition-all duration-500" id="progress-bar" style="width:33%;background:#97BF0D"></div>
          </div>
        </div>

        <!-- Step 1 -->
        <div id="fs-1" class="fstep">
          <h2 class="hd text-[#1B2A4A] mb-1" style="font-size:2.2rem">Wer bist du?</h2>
          <p class="text-[#1B2A4A]/50 mb-7 font-semibold">Kurz vorstellen – das war's für Schritt 1.</p>
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <div class="fgroup"><label class="flabel">Vorname *</label><input id="f-fn" type="text" class="finput" placeholder="Max" /></div>
              <div class="fgroup"><label class="flabel">Nachname *</label><input id="f-ln" type="text" class="finput" placeholder="Mustermann" /></div>
            </div>
            <div class="fgroup"><label class="flabel">Alter *</label><input id="f-age" type="number" class="finput" placeholder="21" min="18" /></div>
          </div>
