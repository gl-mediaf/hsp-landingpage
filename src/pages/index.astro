---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="hsp – Der Ferienjob mit dem gewissen Etwas"
  description="Mach Ø 3.300 € in 4 Wochen. Für den guten Zweck von Tür zu Tür. Jetzt anfragen."
>

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

<div id="app">

  <!-- ══════════════════════════════════════════════
       PAGE 1
  ══════════════════════════════════════════════════ -->
  <div id="page-1" class="page active">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 nav-bar">
      <div class="logo">hsp</div>
      <div class="hidden md:flex gap-8 text-sm font-bold text-[#1B2A4A]/70">
        <a href="#was-du-machst" class="hover:text-[#E5007D] transition-colors">Was du machst</a>
        <a href="#community" class="hover:text-[#E5007D] transition-colors">Community</a>
      </div>
      <button onclick="goToPage(3)" class="btn-nav">Jetzt anfragen →</button>
    </nav>

    <!-- HERO -->
    <section class="hero-wrap relative min-h-screen flex flex-col justify-end overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/3.png" alt="" class="w-full h-full object-cover object-center" />
        <div class="absolute inset-0 hero-gradient"></div>
      </div>
      <div class="relative z-10 px-6 md:px-16 pb-20 pt-32 max-w-5xl">
        <div class="inline-flex items-center gap-2 bg-white/90 rounded-full px-4 py-2 mb-6 shadow-sm">
          <span class="w-2 h-2 rounded-full bg-[#97BF0D] animate-pulse"></span>
          <span class="text-[#1B2A4A] text-sm font-bold">Jetzt für Sommer & Herbst verfügbar</span>
        </div>
        <h1 class="headline-xl text-white mb-6">
          3 Monate<br />
          <span class="text-[#97BF0D]">arbeiten.</span><br />
          9 Monate<br />
          reisen.
        </h1>
        <p class="text-white/80 text-lg md:text-xl max-w-xl leading-relaxed font-semibold">
          Für den guten Zweck von Tür zu Tür unterwegs –<br class="hidden md:block" />
          und dabei richtig gutes Geld machen.
        </p>
        <div class="mt-12 flex items-center gap-3 text-white/50 text-sm font-semibold">
          <div class="scroll-dot-wrap"><span class="scroll-dot"></span></div>
          Scroll
        </div>
      </div>
    </section>

    <!-- STATS BAR -->
    <section class="bg-[#1B2A4A]">
      <div class="max-w-6xl mx-auto px-6 py-5 flex flex-wrap items-center justify-center md:justify-between gap-6">
        {[
          { num: 'Ø 3.300 €', label: 'in 4 Wochen', color: '#97BF0D' },
          { num: '25+',       label: 'Jahre Erfahrung', color: '#00B4D8' },
          { num: '18+',       label: 'Mindestalter', color: '#E5007D' },
          { num: 'Jan–Nov',   label: 'Verfügbar', color: '#97BF0D' },
        ].map((s, i) => (
          <>
            <div class="flex flex-col items-center gap-0.5">
              <span class="headline-sm" style={`color:${s.color}`}>{s.num}</span>
              <span class="text-white/50 text-xs font-semibold uppercase tracking-wider">{s.label}</span>
            </div>
            {i < 3 && <div class="hidden md:block w-px h-10 bg-white/10"></div>}
          </>
        ))}
      </div>
    </section>

    <!-- WAS DU MACHST -->
    <section id="was-du-machst" class="bg-white py-24 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="pill bg-[#E5007D]">Was du machst</div>
          <h2 class="headline-lg text-[#1B2A4A] mt-4">
            Du überzeugst<br />Menschen für den<br /><span class="text-[#97BF0D]">guten Zweck.</span>
          </h2>
          <p class="text-[#1B2A4A]/70 text-lg leading-relaxed mt-6 mb-8 font-medium">
            Als Fundraiser bist du für renommierte Hilfsorganisationen von Tür zu Tür
            unterwegs – und begeisterst Menschen im direkten Gespräch für fördernde
            Mitgliedschaften. Nicht einfach. Genau deshalb machst du richtig gutes Geld.
          </p>
          <ul class="space-y-4">
            {[
              'Direkter Kontakt – persönlich & überzeugend',
              'Modernes Tablet für reibungslose Abwicklung',
              'Crew Coach begleitet dich von Tag 1',
              'Freiwillige Coachings: Rhetorik, Sales & Kommunikation',
            ].map((item, i) => (
              <li class="flex items-start gap-3 text-[#1B2A4A]/80 font-semibold">
                <span class="mt-1 shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-black"
                  style={`background:${['#97BF0D','#E5007D','#00B4D8','#1B2A4A'][i]}`}>
                  ✓
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img src="/images/1.png" alt="Fundraiser im Gespräch" class="w-full rounded-3xl object-cover aspect-[4/5] shadow-xl" />
          <div class="absolute -bottom-5 -left-5 bg-[#97BF0D] rounded-2xl px-5 py-4 shadow-xl">
            <p class="text-white font-black text-2xl headline-sm">Ø 3.300 €</p>
            <p class="text-white/80 text-sm font-bold">in 4 Wochen</p>
          </div>
        </div>
      </div>

      <!-- Org logos -->
      <div class="max-w-6xl mx-auto mt-20 text-center">
        <p class="text-[#1B2A4A]/40 text-xs font-bold uppercase tracking-widest mb-8">Unterwegs für diese Organisationen</p>
        <div class="flex flex-wrap items-center justify-center gap-10">
          {['Deutsches Rotes Kreuz', 'BUND', 'Malteser', 'BN Bayern', 'Österr. Rotes Kreuz'].map(org => (
            <span class="text-[#1B2A4A]/60 font-extrabold text-sm">{org}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- PHONE MOCKUP – UGC -->
    <section class="bg-[#F0F7FF] py-24 px-6 overflow-hidden">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
        <div class="md:w-1/2">
          <div class="pill bg-[#00B4D8]">Ein Tag als Fundraiser</div>
          <h2 class="headline-lg text-[#1B2A4A] mt-4">
            Schau rein –<br /><span class="text-[#E5007D]">echter Alltag.</span>
          </h2>
          <p class="text-[#1B2A4A]/70 text-lg leading-relaxed mt-6 font-medium">
            Kein Büro, kein 9-to-5. Du bist draußen, im Gespräch,
            mit deiner Crew unterwegs – und wächst mit jeder Tür.
          </p>
        </div>
        <div class="md:w-1/2 flex justify-center">
          <div class="phone-mockup">
            <div class="phone-notch"></div>
            <div class="phone-screen" id="ugc-screen">
              <div class="ugc-slides" id="ugc-slides">
                {[
                  { img: '/images/4.png', tag: '@fundraiser_life',  text: 'Tag 3 – schon 12 EH heute 🔥' },
                  { img: '/images/7.png', tag: '@hsp_crew',         text: 'Crew Dinner nach nem langen Tag 🍕' },
                  { img: '/images/2.png', tag: '@leo.fundraiser',   text: 'Woche 2 – Faktor steigt, Konto auch 💸' },
                ].map(s => (
                  <div class="ugc-slide">
                    <img src={s.img} alt="" />
                    <div class="ugc-overlay">
                      <p class="ugc-tag">{s.tag}</p>
                      <p class="ugc-text">{s.text}</p>
                    </div>
                  </div>
                ))}
              </div>
              <div class="ugc-dots">
                <span class="ugc-dot active" onclick="goToSlide(0)"></span>
                <span class="ugc-dot"        onclick="goToSlide(1)"></span>
                <span class="ugc-dot"        onclick="goToSlide(2)"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMUNITY -->
    <section id="community" class="bg-white py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="pill bg-[#97BF0D] mx-auto w-fit">Community</div>
          <h2 class="headline-lg text-[#1B2A4A] text-center mt-4">
            Deine Community<br /><span class="text-[#E5007D]">wartet auf dich.</span>
          </h2>
          <p class="text-[#1B2A4A]/60 text-lg mt-4 max-w-xl mx-auto font-medium">
            Neue Freundschaften, unvergessliche Erlebnisse, echte Verbindungen.
          </p>
        </div>
        <div class="community-grid">
          <img src="/images/6.png"  alt="" class="community-img tall" />
          <img src="/images/8.png"  alt="" class="community-img" />
          <img src="/images/10.png" alt="" class="community-img" />
          <img src="/images/5.png"  alt="" class="community-img tall" />
          <img src="/images/11.png" alt="" class="community-img" />
          <img src="/images/12.png" alt="" class="community-img" />
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="bg-[#1B2A4A] py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <div class="pill bg-[#E5007D] mx-auto w-fit">Bewertungen</div>
          <div class="flex items-center justify-center gap-2 mt-4">
            <span class="text-yellow-400 text-2xl tracking-tight">★★★★★</span>
            <span class="text-white font-black text-xl headline-sm">4.8</span>
            <span class="text-white/40 text-sm font-semibold">auf Google</span>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { name: 'Maximilian K.', age: 22, color: '#97BF0D', text: 'Dieser Job hat mich verändert. Ich rede heute mit jedem – selbstbewusst, klar, überzeugend. Das Geld war super, aber die Skills sind unbezahlbar.' },
            { name: 'Lena S.',       age: 20, color: '#E5007D', text: 'In 4 Wochen mehr gemacht als in meinem letzten Sommerjob in einem halben Jahr. Und das für einen guten Zweck. Kann ich nur empfehlen.' },
            { name: 'Jonas M.',      age: 24, color: '#00B4D8', text: 'Die Community ist das Beste. Man kommt als Fremder und geht mit Freunden fürs Leben. Nebenbei macht man richtig gutes Geld.' },
          ].map(r => (
            <div class="review-card">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-11 h-11 rounded-full flex items-center justify-center text-white font-black text-base headline-sm"
                  style={`background:${r.color}`}>{r.name[0]}</div>
                <div>
                  <p class="text-white font-bold text-sm">{r.name}, {r.age}</p>
                  <div class="text-yellow-400 text-xs mt-0.5">★★★★★</div>
                </div>
              </div>
              <p class="text-white/70 text-sm leading-relaxed font-medium">"{r.text}"</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="https://www.google.com/search?q=hsp+DIE+FUNDRAISER+GmbH+Rezensionen" target="_blank"
            class="text-[#97BF0D]/80 hover:text-[#97BF0D] text-sm font-bold underline transition-colors">
            Alle Bewertungen auf Google lesen →
          </a>
        </div>
      </div>
    </section>

    <!-- CTA TO PAGE 2 -->
    <section class="bg-[#97BF0D] py-28 px-6 text-center">
      <h2 class="headline-lg text-white max-w-2xl mx-auto">
        Wie viel kannst<br />du machen?
      </h2>
      <p class="text-white/80 text-lg mt-4 mb-10 max-w-lg mx-auto font-semibold">
        Kein fixes Gehalt – du bestimmst deinen Einsatz. Rechne selbst nach.
      </p>
      <button onclick="goToPage(2)" class="btn-dark text-lg px-10 py-4">
        Dein Geld ausrechnen →
      </button>
    </section>

  </div><!-- /page-1 -->


  <!-- ══════════════════════════════════════════════
       PAGE 2 — GELD MACHEN + RECHNER
  ══════════════════════════════════════════════════ -->
  <div id="page-2" class="page">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 nav-bar">
      <button onclick="goToPage(1)" class="text-[#1B2A4A]/50 hover:text-[#1B2A4A] transition-colors text-sm font-bold">← Zurück</button>
      <div class="logo">hsp</div>
      <button onclick="goToPage(3)" class="btn-nav">Jetzt anfragen →</button>
    </nav>

    <!-- Mindestgarantie -->
    <section class="bg-white pt-28 pb-16 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="pill bg-[#1B2A4A] mx-auto w-fit mb-4">So machst du dein Geld</div>
        <h2 class="headline-lg text-[#1B2A4A] text-center mb-4">
          Dein Geld.<br /><span class="text-[#97BF0D]">Dein Einsatz.</span>
        </h2>
        <p class="text-[#1B2A4A]/60 text-lg text-center max-w-xl mx-auto mb-14 font-medium">
          Du wirst nach Provision bezahlt. Je mehr du begeisterst, desto mehr machst du.
          Als Sicherheitsnetz gibt's eine garantierte Basis.
        </p>

        <!-- Guarantee card -->
        <div class="guarantee-card mb-6">
          <div class="flex flex-col md:flex-row md:items-center gap-8">
            <div class="md:w-1/3">
              <p class="text-[#1B2A4A]/40 text-xs font-bold uppercase tracking-widest mb-2">Garantierte Basis</p>
              <p class="headline-xl" style="color:#97BF0D;font-size:3.5rem">2.400 €</p>
              <p class="text-[#1B2A4A]/50 mt-1 text-sm font-semibold">Mindestprovision in 4 Wochen</p>
            </div>
            <div class="md:w-2/3 grid grid-cols-2 md:grid-cols-4 gap-3">
              {[
                { week: 'Woche 1', rate: '55 €', col: '#97BF0D' },
                { week: 'Woche 2', rate: '85 €', col: '#00B4D8' },
                { week: 'Woche 3', rate: '115 €', col: '#E5007D' },
                { week: 'Woche 4', rate: '145 €', col: '#1B2A4A' },
              ].map(w => (
                <div class="week-tile" style={`border-top:3px solid ${w.col}`}>
                  <p class="text-[#1B2A4A]/40 text-xs font-bold mb-1">{w.week}</p>
                  <p class="headline-sm" style={`color:${w.col}`}>{w.rate}</p>
                  <p class="text-[#1B2A4A]/40 text-xs font-semibold">pro Tag</p>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-6 pt-5 border-t border-[#1B2A4A]/8 flex flex-wrap gap-6">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-[#97BF0D] shrink-0"></span>
              <span class="text-[#1B2A4A]/60 text-sm font-semibold">+ <strong class="text-[#1B2A4A]">200 € Anreisebonus</strong> nach deinem 6. Einsatztag</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-[#E5007D] shrink-0"></span>
              <span class="text-[#1B2A4A]/60 text-sm font-semibold">Provision immer <strong class="text-[#1B2A4A]">"best case"</strong> abgerechnet</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- INTERAKTIVER RECHNER -->
    <section class="bg-[#F0F7FF] py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="pill bg-[#E5007D] mx-auto w-fit mb-4">Interaktiver Rechner</div>
        <h2 class="headline-lg text-[#1B2A4A] text-center mb-12">
          Rechne deinen<br /><span class="text-[#E5007D]">Einsatz durch.</span>
        </h2>

        <!-- Org selector -->
        <div class="mb-8">
          <p class="text-[#1B2A4A]/50 text-xs font-bold uppercase tracking-widest mb-3 text-center">Organisation wählen</p>
          <div class="flex flex-wrap gap-3 justify-center" id="org-grid"></div>
        </div>

        <!-- Main calculator: chart left, photo right -->
        <div class="calc-main-grid">

          <!-- LEFT: curve chart -->
          <div class="chart-panel">
            <div class="chart-header">
              <div class="zone-labels">
                <span class="zone-lbl newcomer-lbl">NEWCOMER</span>
                <span class="zone-lbl pro-lbl">PRO</span>
                <span class="zone-lbl elite-lbl">ELITE</span>
              </div>
            </div>

            <div class="chart-wrap" id="chart-wrap">
              <svg id="provision-chart" class="provision-svg" viewBox="0 0 600 280" preserveAspectRatio="none">
                <!-- background zones filled by JS -->
                <g id="chart-bg"></g>
                <!-- grid lines -->
                <g id="chart-grid"></g>
                <!-- curve path -->
                <path id="chart-curve" fill="none" stroke="#E5007D" stroke-width="3" stroke-linecap="round"/>
                <!-- area under curve -->
                <path id="chart-area" fill="url(#curveGrad)" opacity="0.3"/>
                <!-- cursor line -->
                <line id="cursor-line" x1="0" y1="0" x2="0" y2="280" stroke="#1B2A4A" stroke-width="1.5" stroke-dasharray="4,3" opacity="0" />
                <!-- cursor dot -->
                <circle id="cursor-dot" cx="0" cy="0" r="6" fill="#E5007D" opacity="0" />
                <!-- gradient def -->
                <defs>
                  <linearGradient id="curveGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#E5007D"/>
                    <stop offset="100%" stop-color="#E5007D" stop-opacity="0"/>
                  </linearGradient>
                </defs>
              </svg>

              <!-- Tooltip -->
              <div id="chart-tooltip" class="chart-tooltip" style="opacity:0">
                <p class="tt-eh" id="tt-eh">450 EH</p>
                <p class="tt-factor" id="tt-factor">Faktor 5.2</p>
                <p class="tt-money" id="tt-money">2.340 €</p>
              </div>

              <!-- TAKE-OFF marker -->
              <div class="takeoff-marker" id="takeoff-marker">
                <div class="takeoff-line"></div>
                <span class="takeoff-label">TAKE-OFF</span>
              </div>

              <!-- 200€ marker -->
              <div class="bonus-badge">200 € Anreiseprämie</div>
            </div>

            <div class="chart-axis">
              <span>0 EH</span>
              <span class="text-[#1B2A4A]/40 text-xs">EINHEITEN →</span>
              <span id="max-eh-label">900 EH</span>
            </div>

            <!-- Stats row -->
            <div class="stats-row mt-6">
              <div class="stat-box" style="border-color:#97BF0D">
                <p class="stat-label">Faktor</p>
                <p class="stat-val" id="r-factor" style="color:#97BF0D">4.0</p>
              </div>
              <div class="stat-box" style="border-color:#00B4D8">
                <p class="stat-label">Brutto</p>
                <p class="stat-val" id="r-gross" style="color:#00B4D8">0 €</p>
              </div>
              <div class="stat-box" style="border-color:#E5007D">
                <p class="stat-label">Dein Geld</p>
                <p class="stat-val" id="r-net" style="color:#E5007D">200 €</p>
              </div>
            </div>
          </div>

          <!-- RIGHT: contextual photo -->
          <div class="photo-panel">
            <div class="photo-wrap" id="photo-wrap">
              <img id="context-photo" src="https://images.unsplash.com/photo-1527786356703-4b100091cd2c?w=600&q=80" alt="" class="context-img" />
              <div class="photo-caption" id="photo-caption">
                <span class="caption-emoji" id="caption-emoji">🗺️</span>
                <span class="caption-text" id="caption-text">Bewege den Cursor über die Kurve</span>
              </div>
            </div>
          </div>

        </div>

        <p class="text-[#1B2A4A]/30 text-xs mt-6 text-center">
          * 20 % Stornorücklage werden nach 1,5 Jahren verrechnet und ggf. zurückerstattet. Alle Angaben sind Beispielrechnungen ohne Gewähr.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#E5007D] py-28 px-6 text-center">
      <h2 class="headline-lg text-white max-w-xl mx-auto">
        Klingt gut?<br />Dann frag an.
      </h2>
      <p class="text-white/80 text-lg mt-4 mb-10 max-w-md mx-auto font-semibold">
        Wir melden uns innerhalb von 24 Stunden. Keine Verpflichtung.
      </p>
      <button onclick="goToPage(3)" class="btn-light text-lg px-10 py-4">
        Jetzt anfragen →
      </button>
    </section>

  </div><!-- /page-2 -->


  <!-- ══════════════════════════════════════════════
       PAGE 3 — MULTI-STEP FORM
  ══════════════════════════════════════════════════ -->
  <div id="page-3" class="page">

    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 nav-bar">
      <button onclick="goToPage(2)" class="text-[#1B2A4A]/50 hover:text-[#1B2A4A] transition-colors text-sm font-bold">← Zurück</button>
      <div class="logo">hsp</div>
      <div></div>
    </nav>

    <section class="min-h-screen bg-white flex items-center justify-center px-6 pt-24 pb-16">
      <div class="w-full max-w-lg">

        <!-- Progress -->
        <div class="mb-10">
          <div class="flex justify-between text-xs text-[#1B2A4A]/40 font-bold mb-2">
            <span id="step-label">Schritt 1 von 3</span>
            <span id="step-pct">33 %</span>
          </div>
          <div class="h-2 bg-[#1B2A4A]/10 rounded-full overflow-hidden">
            <div class="h-full bg-[#97BF0D] rounded-full transition-all duration-500" id="progress-bar" style="width:33%"></div>
          </div>
        </div>

        <!-- Step 1 -->
        <div id="fs-1" class="fstep">
          <h2 class="headline-lg text-[#1B2A4A] mb-2">Wer bist du?</h2>
          <p class="text-[#1B2A4A]/50 mb-8 font-medium">Kurz vorstellen – das war's für Schritt 1.</p>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div class="fgroup"><label class="flabel">Vorname *</label><input id="f-fn" type="text" class="finput" placeholder="Max" /></div>
              <div class="fgroup"><label class="flabel">Nachname *</label><input id="f-ln" type="text" class="finput" placeholder="Mustermann" /></div>
            </div>
            <div class="fgroup"><label class="flabel">Alter *</label><input id="f-age" type="number" class="finput" placeholder="21" min="18" /></div>
          </div>
          <button onclick="nextStep(2)" class="btn-primary w-full mt-8 py-4">Weiter →</button>
        </div>

        <!-- Step 2 -->
        <div id="fs-2" class="fstep hidden">
          <h2 class="headline-lg text-[#1B2A4A] mb-2">Wie erreichst du dich?</h2>
          <p class="text-[#1B2A4A]/50 mb-8 font-medium">Damit wir uns melden können.</p>
          <div class="space-y-4">
            <div class="fgroup"><label class="flabel">E-Mail *</label><input id="f-email" type="email" class="finput" placeholder="max@beispiel.de" /></div>
            <div class="fgroup"><label class="flabel">Telefon *</label><input id="f-phone" type="tel" class="finput" placeholder="+49 ..." /></div>
            <div class="fgroup">
              <label class="flabel">Beste Erreichbarkeit</label>
              <select id="f-reach" class="finput">
                <option value="">Bitte wählen …</option>
                <option>Vormittags</option><option>Mittags</option><option>Nachmittags</option><option>Abends</option>
              </select>
            </div>
          </div>
          <div class="flex gap-3 mt-8">
            <button onclick="nextStep(1)" class="btn-outline flex-1 py-4">← Zurück</button>
            <button onclick="nextStep(3)" class="btn-primary flex-1 py-4">Weiter →</button>
