<!-- ──────────────────────────────────────────── SCRIPTS ── -->
<script>
  /* ── Page nav ──────────────────────────── */
  function goToPage(n) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const pg = document.getElementById('page-' + n);
    if (pg) { pg.classList.add('active'); window.scrollTo({ top: 0 }); }
    if (n === 2) setTimeout(initChart, 100);
  }

  /* ── UGC slider ────────────────────────── */
  let slide = 0;
  function goToSlide(i) {
    slide = i;
    const el = document.getElementById('ugc-slides');
    if (el) el.style.transform = `translateX(-${i*(100/3)}%)`;
    document.querySelectorAll('.ugc-dot').forEach((d,j) => d.classList.toggle('active', j===i));
  }
  setInterval(() => goToSlide((slide+1)%3), 3400);

  let tx = 0;
  document.addEventListener('DOMContentLoaded', () => {
    const sc = document.getElementById('ugc-screen');
    if (!sc) return;
    sc.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, {passive:true});
    sc.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - tx;
      if (Math.abs(dx)>40) goToSlide(dx<0 ? Math.min(slide+1,2) : Math.max(slide-1,0));
    });
  });

  /* ── Org data ──────────────────────────── */
  const ORGS = [
    { id:'brk',  name:'BRK',       newcomer:4,  elite:7,  takeoff:550,  max:2750 },
    { id:'drk',  name:'DRK',       newcomer:5,  elite:8,  takeoff:450,  max:2250 },
    { id:'mhd',  name:'Malteser',  newcomer:6,  elite:9,  takeoff:400,  max:2000 },
    { id:'bn',   name:'BN Bayern', newcomer:7,  elite:11, takeoff:300,  max:1500 },
    { id:'bund', name:'BUND',      newcomer:9,  elite:13, takeoff:250,  max:1250 },
  ];
  let curOrg = ORGS[0];
  const MAX_EH = 900;

  function getFactor(org, eh) {
    if (eh <= org.takeoff) return org.newcomer;
    if (eh >= org.max)     return org.elite;
    return org.newcomer + (eh - org.takeoff) / (org.max - org.takeoff) * (org.elite - org.newcomer);
  }

  function getNet(org, eh) {
    return eh * getFactor(org, eh) * 0.8 + 200;
  }

  function fmt(n) { return Math.round(n).toLocaleString('de-DE') + ' €'; }

  /* ── Photos ────────────────────────────── */
  const PHOTOS = [
    { min:0,    url:'https://images.unsplash.com/photo-1527786356703-4b100091cd2c?w=600&q=80', emoji:'🗺️', text:'Bewege den Cursor über die Kurve' },
    { min:300,  url:'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=600&q=80', emoji:'🎒', text:'Wochenend-Trip finanziert' },
    { min:800,  url:'https://images.unsplash.com/photo-1493676304819-0d7a8d026dcf?w=600&q=80', emoji:'🎪', text:'Festival-Sommer komplett' },
    { min:1500, url:'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=600&q=80', emoji:'✈️', text:'1 Monat Backpacking' },
    { min:2500, url:'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80', emoji:'🚴', text:'Neues Rennrad' },
    { min:3200, url:'https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=600&q=80', emoji:'🌏', text:'2 Monate Südostasien' },
    { min:4000, url:'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=600&q=80', emoji:'🏄', text:'Surf-Trip Bali + Unterkunft' },
  ];

  function updatePhoto(net) {
    let chosen = PHOTOS[0];
    PHOTOS.forEach(p => { if (net >= p.min) chosen = p; });
    const img = document.getElementById('context-photo');
    const cap = document.getElementById('caption-text');
    const emo = document.getElementById('caption-emoji');
    if (img && img.src !== chosen.url) {
      img.style.opacity = '0';
      setTimeout(() => { img.src = chosen.url; img.style.opacity = '1'; }, 300);
    }
    if (cap) cap.textContent = chosen.text;
    if (emo) emo.textContent = chosen.emoji;
  }

  /* ── Chart ─────────────────────────────── */
  let chartInited = false;

  function initChart() {
    if (chartInited) { redrawChart(); return; }
    chartInited = true;

    /* org buttons */
    const grid = document.getElementById('org-grid');
    if (grid && grid.children.length === 0) {
      ORGS.forEach((org, i) => {
        const btn = document.createElement('button');
        btn.className = 'org-btn' + (i===0?' active':'');
        btn.innerHTML = `<span class="org-name">${org.name}</span><span class="org-fac">Faktor ${org.newcomer}–${org.elite}</span>`;
        btn.onclick = () => {
          document.querySelectorAll('.org-btn').forEach(b=>b.classList.remove('active'));
          btn.classList.add('active');
          curOrg = org;
          redrawChart();
        };
        grid.appendChild(btn);
      });
    }

    redrawChart();

    /* mouse interaction */
    const wrap = document.getElementById('chart-wrap');
    if (wrap) {
      wrap.addEventListener('mousemove', onChartMove);
      wrap.addEventListener('mouseleave', onChartLeave);
      wrap.addEventListener('touchmove', e => {
        const r = wrap.getBoundingClientRect();
        onChartMove({ clientX: e.touches[0].clientX, currentTarget: wrap, rect: r });
      }, {passive:true});
    }
  }

  function ehToX(eh, W) { return (eh / MAX_EH) * W; }
  function factorToY(f, H, minF, maxF) { return H - ((f - minF) / (maxF - minF)) * (H * 0.8) - H*0.1; }

  function redrawChart() {
    const svg = document.getElementById('provision-chart');
    if (!svg) return;
    const W = 600, H = 280;
    const org = curOrg;
    const minF = org.newcomer * 0.9;
    const maxF = org.elite * 1.05;

    /* build points */
    const pts = [];
    for (let eh = 0; eh <= MAX_EH; eh += 10) {
      const f = getFactor(org, eh);
      pts.push({ x: ehToX(eh, W), y: factorToY(f, H, minF, maxF), eh, f });
    }

    /* curve path */
    const d = pts.map((p,i) => (i===0?`M${p.x},${p.y}`:`L${p.x},${p.y}`)).join(' ');
    document.getElementById('chart-curve').setAttribute('d', d);

    /* area */
    const areaD = d + ` L${W},${H} L0,${H} Z`;
    document.getElementById('chart-area').setAttribute('d', areaD);

    /* bg zones */
    const bg = document.getElementById('chart-bg');
    const tX = ehToX(org.takeoff, W);
    const mX = ehToX(Math.min(org.max, MAX_EH), W);
    bg.innerHTML = `
      <rect x="0" y="0" width="${tX}" height="${H}" fill="#E0F4FF" opacity="0.6"/>
      <rect x="${tX}" y="0" width="${mX-tX}" height="${H}" fill="#FFE0F0" opacity="0.4"/>
      <rect x="${mX}" y="0" width="${W-mX}" height="${H}" fill="#F0FFE0" opacity="0.4"/>
    `;

    /* grid lines */
    const grid = document.getElementById('chart-grid');
    let gl = '';
    for (let i=1; i<5; i++) {
      const y = (H/5)*i;
      gl += `<line x1="0" y1="${y}" x2="${W}" y2="${y}" stroke="rgba(27,42,74,0.06)" stroke-width="1"/>`;
    }
    grid.innerHTML = gl;

    /* takeoff marker */
    const pct = (org.takeoff / MAX_EH * 100);
    const mkr = document.getElementById('takeoff-marker');
    if (mkr) { mkr.style.left = pct+'%'; }

    /* max EH label */
    document.getElementById('max-eh-label').textContent = MAX_EH+' EH';

    /* init display at takeoff */
    updateDisplay(org.takeoff);
  }

  function onChartMove(e) {
    const wrap = document.getElementById('chart-wrap');
    if (!wrap) return;
    const rect = wrap.getBoundingClientRect();
    const relX = e.clientX - rect.left;
    const pct  = Math.max(0, Math.min(1, relX / rect.width));
    const eh   = Math.round(pct * MAX_EH / 10) * 10;

    /* SVG coordinates */
    const svgW = 600, svgH = 280;
    const svgX = pct * svgW;
    const org  = curOrg;
    const f    = getFactor(org, eh);
    const minF = org.newcomer * 0.9;
    const maxF = org.elite * 1.05;
    const svgY = factorToY(f, svgH, minF, maxF);

    /* cursor line & dot */
    const line = document.getElementById('cursor-line');
    const dot  = document.getElementById('cursor-dot');
    if (line) { line.setAttribute('x1', svgX); line.setAttribute('x2', svgX); line.style.opacity='1'; }
    if (dot)  { dot.setAttribute('cx', svgX); dot.setAttribute('cy', svgY); dot.style.opacity='1'; }

    /* tooltip */
    const tt = document.getElementById('chart-tooltip');
    if (tt) {
      const net = getNet(org, eh);
      document.getElementById('tt-eh').textContent     = eh+' EH';
      document.getElementById('tt-factor').textContent = 'Faktor '+getFactor(org,eh).toFixed(1);
      document.getElementById('tt-money').textContent  = fmt(net);
      const ttX = relX;
      const ttY = (svgY/svgH)*rect.height;
      tt.style.left    = ttX+'px';
      tt.style.top     = ttY+'px';
      tt.style.opacity = '1';
      updatePhoto(net);
    }

    updateDisplay(eh);
  }

  function onChartLeave() {
    document.getElementById('cursor-line').style.opacity='0';
    document.getElementById('cursor-dot').style.opacity='0';
    document.getElementById('chart-tooltip').style.opacity='0';
  }

  function updateDisplay(eh) {
    const org    = curOrg;
    const factor = getFactor(org, eh);
    const gross  = eh * factor;
    const net    = gross * 0.8 + 200;
    const fEl    = document.getElementById('r-factor');
    const gEl    = document.getElementById('r-gross');
    const nEl    = document.getElementById('r-net');
    if (fEl) fEl.textContent = factor.toFixed(1);
    if (gEl) gEl.textContent = fmt(gross);
    if (nEl) nEl.textContent = fmt(net);
  }

  /* ── Form steps ────────────────────────── */
  function nextStep(n) {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-'+n)?.classList.remove('hidden');
    const p = {1:33,2:66,3:100}[n]||33;
    const bar = document.getElementById('progress-bar');
    if (bar) bar.style.width = p+'%';
    document.getElementById('step-label').textContent = 'Schritt '+n+' von 3';
    document.getElementById('step-pct').textContent   = p+' %';
  }

  function submitForm() {
    [1,2,3].forEach(i => document.getElementById('fs-'+i)?.classList.add('hidden'));
    document.getElementById('fs-ok')?.classList.remove('hidden');
    document.getElementById('progress-bar').style.width = '100%';
  }

  window.goToPage  = goToPage;
  window.goToSlide = goToSlide;
  window.nextStep  = nextStep;
  window.submitForm= submitForm;
</script>

</Layout>
